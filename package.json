{
  "name": "artometrics",
  "main": "expo-router/entry",
  "version": "0.0.1",
  "private": true,
  "description": "Artometrics — data reports on culture, power, and the creative economy (Expo for app + web)",
  "scripts": {
    "content": "node scripts/build-content.mjs",
    "prestart": "npm run content && npm run cos:downloads",
    "preweb": "npm run content && npm run cos:downloads",
    "prebuild": "npm run content && npm run cos:downloads",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "dev": "expo start --web",
    "build": "npm run content && npm run cos:downloads && npm run cos:aeo && expo export -p web",
    "sync:episodes": "node scripts/sync-member-episodes.mjs",
    "sync:articles": "node scripts/sync-github-articles.mjs",
    "sync:readmitted": "node scripts/sync-readmitted.mjs",
    "scaffold:repo": "node scripts/scaffold-article-repo.mjs",
    "upgrade:repos": "node scripts/upgrade-article-repos.mjs",
    "publish:repos": "node scripts/publish-article-repos.mjs",
    "migration:manifest": "node scripts/write-migration-manifest.mjs",
    "render:readmitted": "Rscript scripts/render-readmitted-charts.R",
    "render:readmitted:py": "python3 scripts/render-readmitted-charts.py",
    "setup:r": "Rscript scripts/install-r-deps.R",
    "setup:python": "pip3 install -r requirements.txt",
    "setup:pipeline": "bash scripts/setup-pipeline.sh",
    "setup:clis": "bash scripts/setup-product-clis.sh",
    "doctor": "bash scripts/doctor-env.sh",
    "cos:brief": "node scripts/content-os/new-brief.mjs",
    "cos:scaffold": "node scripts/content-os/scaffold-from-brief.mjs",
    "cos:banner-prompt": "node scripts/content-os/banner-prompt.mjs",
    "cos:publish": "node scripts/content-os/publish-draft.mjs",
    "cos:llms": "node scripts/content-os/generate-llms-txt.mjs",
    "cos:aeo": "node scripts/content-os/aeo-pack.mjs",
    "cos:downloads": "node scripts/content-os/pack-article-downloads.mjs",
    "cos:zine": "node scripts/content-os/pack-ig-zine.mjs",
    "cos:pdf": "node scripts/content-os/pack-pdf.mjs",
    "brand:favicons": "python3 scripts/brand/generate-favicons.py",
    "cos:ebook": "node scripts/content-os/pack-ebook.mjs",
    "cos:narrate": "node scripts/content-os/narrate-elevenlabs.mjs",
    "cos:magazine-cleanup": "node scripts/content-os/magazine-body-cleanup.mjs",
    "cos:rainfall-pass": "node scripts/content-os/rainfall-article-pass.mjs",
    "cos:rainfall-rewrite": "node scripts/content-os/rainfall-full-rewrite.mjs",
    "charts:backfill": "python3 scripts/backfill-chart-pngs.py",
    "test:chart-toggle": "node scripts/test-chart-mode-toggle.mjs",
    "test:charts": "node scripts/test-charts-smoke.mjs",
    "eas:build:ios": "eas build -p ios --profile production",
    "eas:build:preview": "eas build -p ios --profile preview",
    "eas:submit:ios": "eas submit -p ios --profile production --latest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@supabase/supabase-js": "^2.110.0",
    "expo": "~57.0.8",
    "expo-av": "~16.0.7",
    "expo-clipboard": "~57.0.1",
    "expo-constants": "~57.0.7",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-linking": "~57.0.4",
    "expo-router": "~57.0.8",
    "expo-sharing": "~57.0.7",
    "expo-splash-screen": "~57.0.5",
    "expo-status-bar": "~57.0.1",
    "expo-symbols": "~57.0.1",
    "expo-web-browser": "~57.0.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-reanimated": "4.5.0",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.26.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.10.0",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.12",
    "playwright": "^1.61.1",
    "typescript": "~5.9.2"
  }
}
