{
  "name": "artometrics",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "Artometrics — data reports on culture, power, and the creative economy",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "sync:episodes": "node scripts/sync-member-episodes.mjs",
    "sync:articles": "node scripts/sync-github-articles.mjs",
    "scaffold:repo": "node scripts/scaffold-article-repo.mjs",
    "upgrade:repos": "node scripts/upgrade-article-repos.mjs",
    "publish:repos": "node scripts/publish-article-repos.mjs",
    "migration:manifest": "node scripts/write-migration-manifest.mjs",
    "render:readmitted": "Rscript scripts/render-readmitted-charts.R",
    "render:readmitted:py": "python3 scripts/render-readmitted-charts.py",
    "setup:r": "Rscript scripts/install-r-deps.R",
    "setup:python": "pip3 install -r requirements.txt",
    "setup:pipeline": "bash scripts/setup-pipeline.sh"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@lexingtonthemes/seo": "^0.4.0",
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "astro": "^7.0.0",
    "plotly.js-dist-min": "^3.6.0",
    "reading-time": "^1.5.0",
    "stripe": "^22.3.0",
    "tailwind-scrollbar-hide": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "tailwindcss": "^4.3.1"
  }
}
