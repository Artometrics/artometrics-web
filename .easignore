# Keep EAS iOS archives small. Native loads site assets from artometrics.com.
# Patterns are gitignore-style: use a leading / so we only match the repo root
# (e.g. "supabase/" would also wipe lib/supabase/).

/articles/
/pilot-drafts/
/docs/
/dist/
/.netlify/
/.git/
*.log

# Web CDN content — not required to compile the binary
/public/

# Root tooling only (do NOT use bare "supabase/" — that kills @/lib/supabase)
/scripts/
/supabase/
/store/
*.R
*.Rproj
requirements.txt
