---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import { getCollection } from "astro:content";

const episodes = (await getCollection("podcast"))
  .filter((e) => e.data?.pubDate)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const latest = episodes[0];
---

<section class="border-b border-base-200 bg-base-100">
  <Wrapper variant="standard" class="py-14 md:py-20">
    <div class="mx-auto max-w-3xl text-center">
      <Text tag="p" variant="textXS" class="uppercase tracking-[0.2em] text-accent-700">
        Artometrics Podcast
      </Text>
      <Text
        tag="h1"
        variant="displayMD"
        class="mt-3 font-serif font-light leading-tight text-base-900 text-pretty"
      >
        Interviews on culture, power, and the systems behind the data
      </Text>
      <Text tag="p" variant="textMD" class="mx-auto mt-4 max-w-2xl leading-relaxed text-base-600">
        Long-form conversations with analysts, founders, and historians — the human layer behind every Artometrics report.
      </Text>
      {
        latest && (
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href={`/podcast/interviews/${latest.id}`}
              class="inline-flex items-center rounded-sm bg-base-900 px-5 py-2.5 text-xs font-semibold uppercase tracking-widest text-white transition-colors hover:bg-accent-800"
            >
              Latest episode
            </a>
            <Text tag="p" variant="textXS" class="text-base-500">
              {episodes.length} episodes
            </Text>
          </div>
        )
      }
    </div>
  </Wrapper>
</section>
