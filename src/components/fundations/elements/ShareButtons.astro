---
interface Props {
  url?: string;
  title?: string;
  description?: string;
  contentType?: "blog" | "podcast" | "generic";
  class?: string;
}

const { url, title, description, contentType = "generic", class: className } =
  Astro.props;
---

<div
  class:list={[
    "art-share flex flex-wrap items-center justify-center gap-2 sm:gap-3",
    className,
  ]}
  data-share-root
  data-share-url={url}
  data-share-title={title}
  data-share-description={description}
  data-share-type={contentType}
>
  <span class="sr-only">Share this article</span>
  <button
    type="button"
    data-share="twitter"
    class="art-share__btn"
    aria-label="Share on X"
  >
    X
  </button>
  <button
    type="button"
    data-share="facebook"
    class="art-share__btn"
    aria-label="Share on Facebook"
  >
    Facebook
  </button>
  <button
    type="button"
    data-share="linkedin"
    class="art-share__btn"
    aria-label="Share on LinkedIn"
  >
    LinkedIn
  </button>
  <button
    type="button"
    data-share="copy"
    class="art-share__btn"
    aria-label="Copy link"
  >
    Copy link
  </button>
</div>

<style>
  .art-share__btn {
    font-family: var(--font-sans, "DM Sans", sans-serif);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    line-height: 1;
    padding: 0.55rem 0.8rem;
    border: 1px solid var(--color-base-200, #d5d5d5);
    border-radius: 4px;
    color: var(--color-base-700, #3a3a3a);
    background: #fff;
    cursor: pointer;
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      background 0.15s ease;
  }

  .art-share__btn:hover {
    color: var(--color-accent-700, #c0392b);
    border-color: var(--color-accent-700, #c0392b);
  }

  .art-share__btn.art-share__btn--copied {
    color: #fff;
    background: var(--color-accent-secondary, #2c3e6b);
    border-color: var(--color-accent-secondary, #2c3e6b);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>("[data-share-root]").forEach((root) => {
    const pageUrl = root.dataset.shareUrl || window.location.href;
    const pageTitle = root.dataset.shareTitle || document.title;
    const pageDesc = root.dataset.shareDescription || "";
    const contentType = root.dataset.shareType || "generic";

    let shareText = pageTitle;
    if (contentType === "podcast") {
      shareText = `Listen to this podcast: ${pageTitle}`;
    } else if (contentType === "blog") {
      shareText = `Check out this article: ${pageTitle}`;
    }
    if (pageDesc) shareText += ` — ${pageDesc}`;

    root.querySelector('[data-share="twitter"]')?.addEventListener("click", () => {
      const twitterUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(pageUrl)}`;
      window.open(twitterUrl, "_blank", "noopener,noreferrer");
    });

    root.querySelector('[data-share="facebook"]')?.addEventListener("click", () => {
      const facebookUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`;
      window.open(facebookUrl, "_blank", "noopener,noreferrer");
    });

    root.querySelector('[data-share="linkedin"]')?.addEventListener("click", () => {
      const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`;
      window.open(linkedinUrl, "_blank", "noopener,noreferrer");
    });

    root.querySelector('[data-share="copy"]')?.addEventListener("click", () => {
      const button = root.querySelector<HTMLButtonElement>('[data-share="copy"]');
      if (!button) return;
      void navigator.clipboard.writeText(pageUrl).then(() => {
        const original = button.textContent;
        button.textContent = "Copied";
        button.classList.add("art-share__btn--copied");
        setTimeout(() => {
          button.textContent = original;
          button.classList.remove("art-share__btn--copied");
        }, 1800);
      });
    });
  });
</script>
