---
import { AstroSeo } from "@lexingtonthemes/seo";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
}

const {
  title = "Artometrics",
  description = "Artometrics — editorial analysis of culture, place, history, persona, and power.",
  canonical = "https://artometrics.com/",
  ogImage = "https://artometrics.com/images/content/2025/10/Artometrics-Icon.png",
  ogType = "website",
  publishedTime,
} = Astro.props;

const siteName = "Artometrics";
---

<AstroSeo
  title={title}
  description={description}
  canonical={canonical}
  openGraph={{
    url: canonical,
    title,
    description,
    images: [
      {
        url: ogImage,
        width: 1200,
        height: 630,
        alt: siteName,
        type: "image/png",
      },
    ],
    site_name: siteName,
    type: ogType,
    locale: "en_US",
    ...(publishedTime && ogType === "article"
      ? { article: { publishedTime } }
      : {}),
  }}
  twitter={{
    handle: "@artometrics",
    site: "@artometrics",
    cardType: "summary_large_image",
  }}
/>
