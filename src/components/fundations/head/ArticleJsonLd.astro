---
interface Props {
  headline: string;
  description: string;
  url: string;
  datePublished: string;
  image?: string;
  authorName?: string;
  section?: string;
}

const {
  headline,
  description,
  url,
  datePublished,
  image,
  authorName = "Artometrics",
  section,
} = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  headline,
  description,
  url,
  datePublished,
  dateModified: datePublished,
  author: {
    "@type": "Organization",
    name: authorName,
  },
  publisher: {
    "@type": "Organization",
    name: "Artometrics",
    logo: {
      "@type": "ImageObject",
      url: "https://artometrics.com/images/content/2025/10/Artometrics-Icon.png",
    },
  },
  ...(image ? { image: [image] } : {}),
  ...(section ? { articleSection: section } : {}),
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
