---
interface Props {
  pageSize?: number;
  total: number;
  class?: string;
}

const { pageSize = 18, total, class: className = "" } = Astro.props;
const initial = Math.min(pageSize, total);
---

{
  total > pageSize && (
    <div class:list={["mt-10 flex flex-col items-center gap-3", className]}>
      <p class="text-xs text-base-500">
        Showing <span id="archiveVisibleCount">{initial}</span> of <span id="archiveTotalCount">{total}</span> reports
      </p>
      <button
        type="button"
        id="archiveLoadMore"
        class="inline-flex items-center rounded-sm border border-base-300 bg-white px-5 py-2.5 text-xs font-semibold uppercase tracking-widest text-base-800 transition-colors hover:border-accent-400 hover:text-accent-800"
        data-page-size={pageSize}
      >
        Load more
      </button>
    </div>
  )
}

<script>
  const grid = document.getElementById("archiveGrid");
  const btn = document.getElementById("archiveLoadMore");
  const counter = document.getElementById("archiveVisibleCount");
  const totalEl = document.getElementById("archiveTotalCount");
  if (!grid || !btn) {
    /* archive pagination not on this page */
  } else {
    const pageSize = Number(btn.dataset.pageSize || 18);
    const items = Array.from(grid.querySelectorAll<HTMLElement>(".archive-item"));
    let shownLimit = pageSize;

    function visibleItems() {
      return items.filter(
        (item) => !item.classList.contains("archive-filter-hidden") && !item.classList.contains("hidden")
      );
    }

    const update = () => {
      const visible = visibleItems();
      if (totalEl) totalEl.textContent = String(visible.length);
      visible.forEach((item, i) => {
        item.classList.toggle("archive-page-hidden", i >= shownLimit);
      });
      const shown = Math.min(shownLimit, visible.length);
      if (counter) counter.textContent = String(shown);
      btn.classList.toggle("hidden", shown >= visible.length);
    };

    btn.addEventListener("click", () => {
      shownLimit += pageSize;
      update();
    });

    grid.addEventListener("archive-filter-change", () => {
      shownLimit = pageSize;
      items.forEach((item) => item.classList.remove("archive-page-hidden"));
      update();
    });

    update();
  }
</script>

<style is:global>
  .archive-page-hidden {
    display: none !important;
  }
</style>
