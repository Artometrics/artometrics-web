---
import ShareButtons from "@/components/fundations/elements/ShareButtons.astro";
import { SECTION_META } from "@/data/sections";

interface NavLink {
  title: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  url: string;
  tags: string[];
  previous?: NavLink | null;
  next?: NavLink | null;
  primaryDesk?: keyof typeof SECTION_META | null;
}

const { title, description, url, tags, previous, next, primaryDesk } = Astro.props;
const desks = tags.filter((t): t is keyof typeof SECTION_META => t in SECTION_META);
---

<footer class="art-article-site-footer border-t border-base-200 bg-base-100">
  <div class="mx-auto max-w-3xl px-4 py-10 md:px-6">
    {
      desks.length > 0 && (
        <div class="flex flex-wrap items-center gap-2">
          <span class="text-[10px] font-semibold uppercase tracking-widest text-base-400">
            Filed under
          </span>
          {desks.map((desk) => (
            <a
              href={`/${desk}/`}
              class="rounded-full border border-base-200 bg-white px-3 py-1 text-[10px] font-semibold uppercase tracking-wider text-base-700 transition-colors hover:border-accent-400 hover:text-accent-800"
            >
              {SECTION_META[desk].title}
            </a>
          ))}
        </div>
      )
    }

    <div class="mt-8 flex flex-wrap items-center justify-between gap-4 border-y border-base-200 py-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-base-500">Share this report</p>
      <ShareButtons
        contentType="blog"
        title={title}
        description={description}
        url={url}
      />
    </div>

    {
      (previous || next) && (
        <nav
          class="mt-8 grid gap-4 border-b border-base-200 pb-8 sm:grid-cols-2"
          aria-label="Article navigation"
        >
          {
            previous ? (
              <a
                href={previous.href}
                class="group rounded-md border border-base-200 bg-white p-4 transition-colors hover:border-accent-300 hover:bg-accent-50/40"
              >
                <span class="text-[10px] font-semibold uppercase tracking-widest text-base-400">
                  ← Newer
                </span>
                <span class="mt-2 block text-sm font-semibold leading-snug text-base-900 group-hover:text-accent-800">
                  {previous.title}
                </span>
              </a>
            ) : (
              <div />
            )
          }
          {
            next ? (
              <a
                href={next.href}
                class="group rounded-md border border-base-200 bg-white p-4 text-right transition-colors hover:border-accent-300 hover:bg-accent-50/40 sm:col-start-2"
              >
                <span class="text-[10px] font-semibold uppercase tracking-widest text-base-400">
                  Older →
                </span>
                <span class="mt-2 block text-sm font-semibold leading-snug text-base-900 group-hover:text-accent-800">
                  {next.title}
                </span>
              </a>
            ) : (
              <div />
            )
          }
        </nav>
      )
    }

    <div class="mt-8 flex flex-wrap items-center justify-between gap-4">
      <a
        href={primaryDesk ? `/${primaryDesk}/` : "/blog/"}
        class="text-xs font-medium uppercase tracking-widest text-base-600 transition-colors hover:text-accent-700"
      >
        {primaryDesk ? `More from ${SECTION_META[primaryDesk].title} →` : "All reports →"}
      </a>
      <button
        type="button"
        class="text-xs font-medium uppercase tracking-widest text-base-600 transition-colors hover:text-accent-700"
        onclick="window.print()"
      >
        Print report
      </button>
    </div>

    <p class="art-article-endmark" aria-hidden="true">Artometrics</p>
  </div>
</footer>
