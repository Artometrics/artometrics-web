---
import { SECTION_META } from "@/data/sections";

interface Props {
  primaryDesk?: keyof typeof SECTION_META | null;
}

const { primaryDesk = null } = Astro.props;
const deskLabel = primaryDesk ? SECTION_META[primaryDesk].title : "Artometrics";
---

<aside
  class="mx-auto mt-8 max-w-4xl rounded-sm border border-base-200 bg-base-100 px-5 py-4 md:px-6"
  aria-label="How to read this report"
>
  <div class="grid gap-4 md:grid-cols-[1.2fr_0.8fr] md:items-center">
    <div>
      <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-accent-700">
        Evidence path
      </p>
      <p class="mt-2 text-sm leading-relaxed text-base-700">
        Start with the chart claims, then check the dataset context, limitations, and references.
        This <strong>{deskLabel}</strong> report may combine observed data, derived metrics, and
        clearly labeled editorial interpretation.
      </p>
    </div>
    <nav class="flex flex-wrap gap-2 text-[10px] font-semibold uppercase tracking-wider" aria-label="Report evidence links">
      <a class="rounded-full border border-base-200 bg-white px-3 py-1.5 text-base-700 transition-colors hover:border-accent-400 hover:text-accent-800" href="#dataset-context">
        Data context
      </a>
      <a class="rounded-full border border-base-200 bg-white px-3 py-1.5 text-base-700 transition-colors hover:border-accent-400 hover:text-accent-800" href="#references">
        References
      </a>
      <a class="rounded-full border border-base-200 bg-white px-3 py-1.5 text-base-700 transition-colors hover:border-accent-400 hover:text-accent-800" href="/methodology/">
        Methodology
      </a>
    </nav>
  </div>
</aside>
