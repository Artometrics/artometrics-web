---
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).map((post) => ({
  title: post.data.title,
  pubDate: post.data.pubDate,
  description: post.data.description,
  slug: post.data.slug,
  tags: post.data.tags,
  type: "blog",
  typeLabel: "Report",
  href: `/${post.data.slug}/`,
}));

const podcasts = (await getCollection("podcast")).map((podcast) => ({
  title: podcast.data.title,
  pubDate: podcast.data.pubDate,
  description: podcast.data.description,
  slug: podcast.id,
  type: "podcast",
  typeLabel: "Podcast",
  href: `/podcast/interviews/${podcast.id}`,
}));

const items = [...posts, ...podcasts].sort(
  (a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime()
);

items.unshift({
  title: "Methodology and Sources",
  pubDate: new Date().toISOString(),
  description:
    "How Artometrics uses public datasets, official APIs, literature, derived metrics, editorial indices, and source links.",
  slug: "methodology",
  tags: ["source", "dataset", "literature", "TidyTuesday", "Pantheon", "IMDb", "CMS", "OEC"],
  type: "page",
  typeLabel: "Methodology",
  href: "/methodology/",
});

const suggestions = items.slice(0, 6);
const searchPayload = JSON.stringify({ items, suggestions });
---

<div class="relative">
  <button
    type="button"
    id="searchButton"
    aria-label="Search (Ctrl+K)"
    aria-controls="searchModal"
    aria-expanded="false"
    class="inline-flex items-center gap-2 rounded-md border border-base-200 px-3 py-2 text-xs font-medium uppercase tracking-widest text-base-900 transition-colors hover:border-accent-400 hover:text-accent-700"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.75"/>
      <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
    </svg>
    <span class="hidden sm:inline">Search</span>
    <kbd
      id="searchKbd"
      class="hidden rounded border border-base-200 bg-base-50 px-1.5 py-0.5 text-[10px] font-normal text-base-500 lg:inline"
    >⌘K</kbd>
  </button>

  <div
    id="searchModal"
    class="site-search-modal fixed inset-0 z-[10050] hidden overflow-y-auto"
    role="dialog"
    aria-modal="true"
    aria-labelledby="searchDialogTitle"
  >
    <div class="flex min-h-screen items-start justify-center px-4 py-16 sm:py-24">
      <div
        class="site-search-overlay fixed inset-0 z-0 bg-base-950/55 backdrop-blur-sm"
        id="modalOverlay"
      ></div>
      <div
        class="site-search-panel relative z-10 w-full max-w-2xl overflow-hidden rounded-lg border border-base-200 bg-white shadow-2xl"
      >
        <div class="site-search-input-row flex items-center gap-3 border-b border-base-200 px-4 py-3">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="shrink-0 text-base-400" aria-hidden="true">
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.75"/>
            <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
          </svg>
          <span id="searchDialogTitle" class="sr-only">Search Artometrics</span>
          <input
            type="search"
            id="searchInput"
            placeholder="Search articles and podcast episodes…"
            autocomplete="off"
            enterkeyhint="search"
            class="site-search-input h-10 w-full border-0 bg-transparent text-sm text-base-900 placeholder-base-400 shadow-none ring-0 outline-none focus:border-0 focus:outline-none focus:ring-0 focus-visible:outline-none"
          />
          <button
            type="button"
            id="closeSearch"
            class="shrink-0 rounded-md border border-base-200 px-2 py-1 text-[10px] font-medium uppercase tracking-wide text-base-500 transition-colors hover:border-base-400 hover:text-base-900"
            aria-label="Close search"
          >
            Esc
          </button>
        </div>
        <div
          id="searchResults"
          class="site-search-results max-h-[min(60vh,28rem)] overflow-y-auto divide-y divide-base-100"
        >
          <p class="px-4 pt-4 text-[10px] font-semibold uppercase tracking-widest text-base-400">
            Recent
          </p>
          {
            suggestions.map((item, index) => (
              <a
                href={item.href}
                data-index={index}
                class="search-result block px-4 py-4 transition-colors hover:bg-base-50 focus:bg-base-50 outline-none focus-visible:outline-none"
              >
                <p class="text-[10px] font-semibold uppercase tracking-widest text-accent-700">
                  {item.typeLabel || item.type || "Page"}
                </p>
                <h3 class="mt-1 text-sm font-semibold leading-snug text-base-900">{item.title}</h3>
                <p class="mt-1 line-clamp-2 text-xs leading-relaxed text-base-500">
                  {item.description}
                </p>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</div>

<script id="site-search-data" type="application/json" set:html={searchPayload} />
<script>
  import { initSiteSearch } from "@/scripts/site-search";

  function bootSearch() {
    const dataEl = document.getElementById("site-search-data");
    if (!dataEl?.textContent) return;
    try {
      const payload = JSON.parse(dataEl.textContent);
      initSiteSearch(payload);
    } catch (error) {
      console.error("Artometrics search failed to initialize:", error);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", bootSearch, { once: true });
  } else {
    bootSearch();
  }
</script>
