---
import { getCollection } from "astro:content";
const posts = await Promise.all(
  (await getCollection("blog", ({ data }) => !data.draft)).map(async (post) => ({
    title: post.data.title,
    pubDate: post.data.pubDate,
    description: post.data.description,
    slug: post.data.slug,
    type: "blog",
    typeLabel: "Article",
    href: `/${post.data.slug}/`,
  }))
);
const podcasts = await Promise.all(
  (await getCollection("podcast")).map(async (podcast) => ({
    title: podcast.data.title,
    pubDate: podcast.data.pubDate,
    description: podcast.data.description,
    slug: podcast.id,
    type: "podcast",
    typeLabel: "Podcast",
    href: `/podcast/interviews/${podcast.id}`,
  }))
);
const items = [...posts, ...podcasts];
---

<div class="relative">
  <button
    type="button"
    id="searchButton"
    aria-label="Search (Ctrl+K)"
    class="inline-flex items-center gap-2 rounded-md border border-base-200 px-3 py-2 text-xs font-medium uppercase tracking-widest text-base-900 transition-colors hover:border-accent-400 hover:text-accent-700"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.75"/>
      <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
    </svg>
    <span class="hidden sm:inline">Search</span>
    <kbd class="hidden rounded border border-base-200 bg-base-50 px-1.5 py-0.5 text-[10px] font-normal text-base-500 lg:inline">⌘K</kbd>
  </button>
  <div
    id="searchModal"
    class="fixed inset-0 z-[100] hidden overflow-y-auto"
    role="dialog"
    aria-modal="true"
    aria-labelledby="searchDialogTitle"
  >
    <div class="flex min-h-screen items-start justify-center px-4 py-16 sm:py-24">
      <div
        class="fixed inset-0 bg-base-950/55 backdrop-blur-sm transition-opacity"
        id="modalOverlay"
      ></div>
      <div
        class="relative w-full max-w-2xl overflow-hidden rounded-lg border border-base-200 bg-white shadow-2xl"
      >
        <div class="flex items-center gap-3 border-b border-base-200 px-4 py-3">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="shrink-0 text-base-400" aria-hidden="true">
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.75"/>
            <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
          </svg>
          <span id="searchDialogTitle" class="sr-only">Search Artometrics</span>
          <input
            type="search"
            id="searchInput"
            placeholder="Search articles and podcast episodes…"
            autocomplete="off"
            class="h-10 w-full border-0 bg-transparent text-sm text-base-900 placeholder-base-400 focus:outline-none focus:ring-0"
          />
          <button
            type="button"
            id="closeSearch"
            class="shrink-0 rounded-md border border-base-200 px-2 py-1 text-[10px] font-medium uppercase tracking-wide text-base-500 transition-colors hover:border-base-400 hover:text-base-900"
            aria-label="Close search"
          >
            Esc
          </button>
        </div>
        <div
          id="searchResults"
          class="hidden max-h-[min(60vh,28rem)] overflow-y-auto divide-y divide-base-100"
        ></div>
      </div>
    </div>
  </div>
</div>
<script is:inline define:vars={{ items }}>
  window.addEventListener("load", () => {
    const searchButton = document.getElementById("searchButton");
    const searchModal = document.getElementById("searchModal");
    const modalOverlay = document.getElementById("modalOverlay");
    const searchInput = document.getElementById("searchInput");
    const searchResults = document.getElementById("searchResults");
    const closeSearch = document.getElementById("closeSearch");
    const fuse = new Fuse(items, {
      keys: ["title", "description", "typeLabel"],
      threshold: 0.32,
      includeMatches: true,
    });

    function openSearch(e) {
      if (e) {
        e.preventDefault();
        e.stopPropagation();
      }
      searchModal.classList.remove("hidden");
      document.body.style.overflow = "hidden";
      setTimeout(() => searchInput.focus(), 50);
    }

    function closeSearchModal(e) {
      if (e) {
        e.preventDefault();
        e.stopPropagation();
      }
      searchModal.classList.add("hidden");
      document.body.style.overflow = "";
      searchInput.value = "";
      searchResults.innerHTML = "";
      searchResults.classList.add("hidden");
    }

    function renderResults(results) {
      if (!searchInput.value.trim()) {
        searchResults.innerHTML = "";
        searchResults.classList.add("hidden");
        return;
      }
      if (results.length === 0) {
        searchResults.innerHTML =
          '<p class="p-6 text-center text-sm text-base-500">No matches — try a different keyword.</p>';
        searchResults.classList.remove("hidden");
        return;
      }
      searchResults.innerHTML = results
        .slice(0, 12)
        .map(
          (result) => `
            <a href="${result.item.href}" class="block px-4 py-4 transition-colors hover:bg-base-50">
              <p class="text-[10px] font-semibold uppercase tracking-widest text-accent-700">
                ${result.item.typeLabel || result.item.type}
              </p>
              <h3 class="mt-1 text-sm font-semibold leading-snug text-base-900">${result.item.title}</h3>
              <p class="mt-1 line-clamp-2 text-xs leading-relaxed text-base-500">${result.item.description}</p>
            </a>
          `
        )
        .join("");
      searchResults.classList.remove("hidden");
    }

    searchButton?.addEventListener("click", openSearch);
    closeSearch?.addEventListener("click", closeSearchModal);
    modalOverlay?.addEventListener("click", closeSearchModal);
    searchInput?.addEventListener("input", (e) => {
      const value = e.target.value.trim();
      renderResults(value ? fuse.search(value) : []);
    });

    document.addEventListener("keydown", (e) => {
      const mod = e.metaKey || e.ctrlKey;
      if (mod && e.key.toLowerCase() === "k") {
        e.preventDefault();
        if (searchModal.classList.contains("hidden")) openSearch();
        else closeSearchModal();
      }
      if (e.key === "Escape" && !searchModal.classList.contains("hidden")) {
        closeSearchModal();
      }
    });
  });
</script>
