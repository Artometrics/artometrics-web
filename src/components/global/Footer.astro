---
import Logo from "@/components/assets/Logo.astro";
import Text from "../fundations/elements/Text.astro";
import Wrapper from "../fundations/containers/Wrapper.astro";

const footerLinks = [
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
  { href: "/legal/privacy", label: "Privacy" },
  { href: "/legal/terms", label: "Terms" },
];

const socialLinks = [
  { href: "#_", label: "Facebook" },
  { href: "#_", label: "X" },
  { href: "#_", label: "Instagram" },
  { href: "#_", label: "LinkedIn" },
];
---

<footer class="bg-base-100 border-t border-base-200">
  <Wrapper variant="standard" class="py-12">
    <div class="max-w-md mx-auto text-center">
      <Logo class="text-3xl" />
      <Text tag="p" variant="textXS" class="mt-2 uppercase tracking-widest text-base-500">
        Artometrics Media Industry
      </Text>
      <form class="flex items-center gap-2 mt-6">
        <input
          type="email"
          name="email"
          placeholder="you@example.com"
          class="flex-1 px-3 py-2 text-sm border border-base-300 bg-white focus:outline-none focus:border-accent-700"
          aria-label="Email address"
        />
        <button
          type="submit"
          class="px-4 py-2 text-sm text-white bg-accent-700 hover:bg-accent-800 font-medium"
        >
          Subscribe
        </button>
      </form>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-4 mt-8">
      {
        socialLinks.map((item) => (
          <a
            href={item.href}
            aria-label={item.label}
            class="flex items-center justify-center size-8 rounded-full border border-base-900 text-base-900 hover:bg-base-200"
          >
            <span class="text-[10px] font-bold">{item.label.charAt(0)}</span>
          </a>
        ))
      }
    </div>

    <nav class="flex flex-wrap items-center justify-center gap-4 mt-8 text-xs uppercase">
      {
        footerLinks.map((link) => (
          <a href={link.href} class="text-base-600 hover:text-accent-700">
            {link.label}
          </a>
        ))
      }
    </nav>

    <Text
      tag="p"
      variant="textXS"
      class="mt-8 text-center text-base-500"
    >
      © {new Date().getFullYear()} Artometrics
    </Text>
  </Wrapper>
</footer>
