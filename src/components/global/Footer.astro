---
import Logo from "@/components/assets/Logo.astro";
import Text from "../fundations/elements/Text.astro";
import Wrapper from "../fundations/containers/Wrapper.astro";
import { SECTION_META } from "@/data/sections";

const footerLinks = [
  { href: "/about", label: "About" },
  { href: "/blog/", label: "Reports" },
  { href: "/methodology/", label: "Methodology" },
  { href: "/podcast/", label: "Podcast" },
  { href: "/authors/", label: "Authors" },
  { href: "/contact", label: "Contact" },
  { href: "/rss.xml", label: "RSS" },
  { href: "/legal/ethics-statement", label: "Ethics" },
  { href: "/legal/privacy", label: "Privacy" },
  { href: "/legal/terms", label: "Terms" },
];

const socialLinks = [
  {
    href: "https://github.com/Artometrics",
    label: "GitHub",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>`,
  },
  {
    href: "https://twitter.com/artometrics",
    label: "X",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
];
---

<footer class="mt-auto border-t border-base-200 bg-base-100">
  <div class="border-b border-base-200 bg-base-900 text-white">
    <Wrapper variant="standard" class="py-10 md:py-12">
      <div class="mx-auto max-w-2xl text-center">
        <Text tag="p" variant="textXS" class="uppercase tracking-[0.2em] text-base-400">
          Stay in the loop
        </Text>
        <Text tag="h2" variant="displayXS" class="mt-2 font-serif font-light text-pretty">
          Data reports on culture, power, and the creative economy
        </Text>
        <Text tag="p" variant="textSM" class="mt-3 text-base-300">
          New Artometrics reports and podcast episodes — follow on GitHub or subscribe via RSS.
        </Text>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
          <a
            href="/rss.xml"
            class="inline-flex items-center rounded-sm bg-white px-5 py-2.5 text-xs font-semibold uppercase tracking-widest text-base-900 transition-colors hover:bg-accent-100"
          >
            RSS feed
          </a>
          <a
            href="/methodology/"
            class="inline-flex items-center rounded-sm border border-base-600 px-5 py-2.5 text-xs font-semibold uppercase tracking-widest text-white transition-colors hover:border-accent-400 hover:text-accent-200"
          >
            Methodology
          </a>
          <a
            href="https://github.com/Artometrics"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center rounded-sm border border-base-600 px-5 py-2.5 text-xs font-semibold uppercase tracking-widest text-white transition-colors hover:border-accent-400 hover:text-accent-200"
          >
            GitHub →
          </a>
        </div>
      </div>
    </Wrapper>
  </div>

  <Wrapper variant="standard" class="py-14">
    <div class="mx-auto max-w-md text-center">
      <Logo class="text-3xl" />
      <Text tag="p" variant="textXS" class="mt-2 uppercase tracking-[0.18em] text-base-500">
        The Artometrics editorial desk
      </Text>
    </div>

    <nav class="mt-8 flex flex-wrap justify-center gap-2" aria-label="Section desks">
      {
        Object.entries(SECTION_META).map(([slug, meta]) => (
          <a
            href={`/${slug}/`}
            class="rounded-full border border-base-200 bg-white px-3 py-1.5 text-[10px] font-semibold uppercase tracking-wider text-base-700 transition-colors hover:border-accent-400 hover:text-accent-800"
          >
            {meta.title}
          </a>
        ))
      }
    </nav>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      {
        socialLinks.map((item) => (
          <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={item.label}
            class="flex size-9 items-center justify-center rounded-full border border-base-300 text-base-800 transition-colors hover:border-accent-500 hover:bg-white hover:text-accent-700"
          >
            <span set:html={item.icon} />
          </a>
        ))
      }
    </div>

    <nav class="mt-8 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-xs uppercase tracking-wide">
      {
        footerLinks.map((link) => (
          <a href={link.href} class="text-base-600 transition-colors hover:text-accent-700">
            {link.label}
          </a>
        ))
      }
    </nav>

    <Text tag="p" variant="textXS" class="mt-10 text-center text-base-400">
      © {new Date().getFullYear()} Artometrics
    </Text>
  </Wrapper>
</footer>
