---
/** Shared client behaviors: nav scroll shadow, auth, member gating. */
---

<script>
  const nav = document.getElementById("navigation");
  if (nav) {
    const onScroll = () => {
      nav.classList.toggle("site-nav--scrolled", window.scrollY > 8);
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>

<script>
  import { initProductAuth } from "@/scripts/product-auth";
  import { initMemberGate } from "@/scripts/member-gate";

  initProductAuth();
  initMemberGate();
</script>
