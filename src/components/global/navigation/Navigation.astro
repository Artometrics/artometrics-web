---
import Logo from "@/components/assets/Logo.astro";
import Search from "@/components/global/Search.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const navLinks = [
  { href: "/blog/", link: "Reports" },
  { href: "/podcast/", link: "Podcast" },
  { href: "/about", link: "About" },
];

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

function isActive(href: string) {
  const normalized = href.replace(/\/$/, "") || "/";
  if (normalized === "/") return pathname === "/";
  return pathname === normalized || pathname.startsWith(`${normalized}/`);
}
---

<section
  id="navigation"
  class="site-nav sticky top-0 z-40 border-b border-base-200 bg-white/90 backdrop-blur-md transition-shadow duration-300 supports-[backdrop-filter]:bg-white/80"
>
  <Wrapper variant="standard">
    <div class="flex items-center justify-between gap-4 py-4 md:py-5">
      <button
        type="button"
        id="mobileNavToggle"
        class="inline-flex size-10 items-center justify-center rounded-md border border-base-200 text-base-900 transition-colors hover:border-accent-500 hover:text-accent-700 md:hidden"
        aria-expanded="false"
        aria-controls="mobileNavPanel"
        aria-label="Open menu"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        </svg>
      </button>

      <a href="/" class="inline-block shrink-0 md:mx-auto">
        <span class="sr-only">Artometrics home</span>
        <Logo class="text-3xl md:text-4xl lg:text-5xl" />
      </a>

      <div class="flex items-center gap-2 sm:gap-3 md:absolute md:right-8 lg:right-8">
        <div id="navAuthGuest" class="flex items-center gap-2 sm:flex">
          <a
            href="/login/"
            class="text-[10px] font-semibold uppercase tracking-widest text-base-600 transition-colors hover:text-accent-700"
          >
            Sign in
          </a>
          <a
            href="/pricing/"
            class="hidden rounded-full bg-base-900 px-3 py-1.5 text-[10px] font-semibold uppercase tracking-widest text-white transition-colors hover:bg-base-800 sm:inline-flex"
          >
            Subscribe
          </a>
        </div>
        <div id="navAuthUser" class="hidden items-center gap-2">
          <a
            id="navAuthEmail"
            href="/account/"
            class="max-w-[8rem] truncate text-[10px] font-semibold uppercase tracking-widest text-base-600 transition-colors hover:text-accent-700 sm:max-w-[10rem]"
          >
            Account
          </a>
        </div>
        <Search />
      </div>
    </div>

    <nav
      class="hidden items-center justify-center gap-6 border-t border-base-200 pb-4 pt-4 text-xs font-medium uppercase tracking-widest md:flex lg:gap-8"
      aria-label="Primary"
    >
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "nav-link relative transition-colors hover:text-accent-700",
              isActive(link.href)
                ? "text-accent-700 after:absolute after:-bottom-1 after:left-0 after:h-0.5 after:w-full after:bg-accent-600"
                : "text-base-900",
            ]}
          >
            {link.link}
          </a>
        ))
      }
    </nav>

    <div
      id="mobileNavPanel"
      class="hidden border-t border-base-200 pb-4 pt-3 md:hidden"
      hidden
    >
      <nav class="grid gap-1" aria-label="Mobile primary">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                "rounded-md px-3 py-2.5 text-sm font-medium uppercase tracking-wide transition-colors",
                isActive(link.href)
                  ? "bg-accent-50 text-accent-800"
                  : "text-base-900 hover:bg-base-100",
              ]}
            >
              {link.link}
            </a>
          ))
        }
        <a
          href="/login/"
          class="rounded-md px-3 py-2.5 text-sm font-medium uppercase tracking-wide text-base-700 transition-colors hover:bg-base-100"
        >
          Sign in
        </a>
        <a
          href="/account/"
          class="rounded-md px-3 py-2.5 text-sm font-medium uppercase tracking-wide text-base-700 transition-colors hover:bg-base-100"
        >
          Account
        </a>
      </nav>
    </div>
  </Wrapper>
</section>

<script>
  const toggle = document.getElementById("mobileNavToggle");
  const panel = document.getElementById("mobileNavPanel");

  toggle?.addEventListener("click", () => {
    const open = panel?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    if (panel) panel.hidden = !open;
  });
</script>
