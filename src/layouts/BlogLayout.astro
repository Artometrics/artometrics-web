---
import BaseLayout from "./BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import ShareButtons from "@/components/fundations/elements/ShareButtons.astro";
import Breadcrumbs from "@/components/blog/Breadcrumbs.astro";
import ArticleFooter from "@/components/blog/ArticleFooter.astro";
import ArticleJsonLd from "@/components/fundations/head/ArticleJsonLd.astro";
import { getCollection, getEntry } from "astro:content";
import { SECTION_META } from "@/data/sections";
import {
  deckLine,
  getAdjacentPosts,
  getRelatedPosts,
  primaryDesk,
} from "@/lib/blog";
import readingTime from "reading-time";

interface Props {
  frontmatter: {
    title: string;
    pubDate: Date | string;
    description: string;
    heroImage?: string;
    tags?: string[];
    author?: string;
  };
  slug: string;
  readingStats?: ReturnType<typeof readingTime>;
  previous?: { title: string; href: string } | null;
  next?: { title: string; href: string } | null;
}

const { frontmatter, slug, readingStats, previous = null, next = null } = Astro.props;
const tags = frontmatter.tags ?? [];
const desk = primaryDesk(tags);
const deck = deckLine(frontmatter.description);

const pubDateFormatted = new Date(frontmatter.pubDate).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const isoDate = new Date(frontmatter.pubDate).toISOString();
const readLabel = readingStats?.text ?? null;

const authorEntry = frontmatter.author
  ? await getEntry("authors", frontmatter.author)
  : null;
const authorName = authorEntry?.data.name ?? "Artometrics Editorial";
const authorHref = authorEntry ? `/authors/${frontmatter.author}` : null;

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const relatedPosts = getRelatedPosts(allPosts, slug, tags, 6);
const relatedJson = JSON.stringify(relatedPosts);

const articleUrl = new URL(`/${slug}/`, Astro.site ?? "https://artometrics.com").href;
const ogImage = frontmatter.heroImage
  ? new URL(frontmatter.heroImage, Astro.site ?? "https://artometrics.com").href
  : undefined;

const breadcrumbs = [
  { label: "Home", href: "/" },
  ...(desk ? [{ label: SECTION_META[desk].title, href: `/${desk}/` }] : [{ label: "Articles", href: "/blog/" }]),
  { label: frontmatter.title.length > 48 ? `${frontmatter.title.slice(0, 48)}…` : frontmatter.title },
];
---

<BaseLayout
  pageTitle={`${frontmatter.title} — Artometrics`}
  pageDescription={frontmatter.description}
  canonicalPath={`/${slug}/`}
  ogImage={ogImage}
  ogType="article"
  publishedTime={isoDate}
>
  <ArticleJsonLd
    slot="head"
    headline={frontmatter.title}
    description={frontmatter.description}
    url={articleUrl}
    datePublished={isoDate}
    image={ogImage}
    authorName={authorName}
    section={desk ? SECTION_META[desk].title : undefined}
  />
  <link slot="head" rel="stylesheet" href="/css/artometrics-article.css" />

  <article class="artometrics-article">
    <Wrapper variant="standard" class="pt-8 pb-6 md:pt-10">
      <header class="mx-auto max-w-3xl border-b border-base-200 pb-8">
        <Breadcrumbs items={breadcrumbs} class="mb-6 justify-center md:justify-start" />

        {
          desk && (
            <a
              href={`/${desk}/`}
              class="inline-flex rounded-sm bg-accent-50 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.16em] text-accent-800 transition-colors hover:bg-accent-100"
            >
              {SECTION_META[desk].title} desk
            </a>
          )
        }

        <h1 class="mt-4 font-serif text-3xl font-light leading-tight text-base-900 text-pretty md:text-4xl lg:text-[2.35rem]">
          {frontmatter.title}
        </h1>

        <p class="mt-4 font-sans text-lg leading-relaxed text-base-600 text-pretty md:text-xl">
          {deck}
        </p>

        <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs uppercase tracking-wide text-base-500">
          {
            authorHref ? (
              <a href={authorHref} class="font-semibold text-base-700 transition-colors hover:text-accent-700">
                {authorName}
              </a>
            ) : (
              <span class="font-semibold text-base-700">{authorName}</span>
            )
          }
          <span aria-hidden="true">·</span>
          <time datetime={isoDate}>{pubDateFormatted}</time>
          {readLabel && (
            <>
              <span aria-hidden="true">·</span>
              <span>{readLabel}</span>
            </>
          )}
        </div>

        <ShareButtons
          class="mt-6 justify-center md:justify-start"
          contentType="blog"
          title={frontmatter.title}
          description={deck}
          url={articleUrl}
        />
      </header>

      {
        frontmatter.heroImage && (
          <figure class="mx-auto mt-10 max-w-4xl">
            <img
              src={frontmatter.heroImage}
              alt={frontmatter.title}
              width={1200}
              height={675}
              class="aspect-video w-full border border-base-200 bg-base-100 object-cover"
              loading="eager"
              decoding="async"
            />
            <figcaption class="mt-3 text-center text-xs text-base-500">
              {deck}
            </figcaption>
          </figure>
        )
      }
    </Wrapper>

    <div class="artometrics-article-body" data-related={relatedJson}>
      <slot />
    </div>

    <ArticleFooter
      title={frontmatter.title}
      description={deck}
      url={articleUrl}
      slug={slug}
      tags={tags}
      previous={previous}
      next={next}
      primaryDesk={desk}
    />
  </article>

  <script>
    import { initArtCharts } from "@/scripts/art-charts";
    import { initArticleChrome } from "@/scripts/art-article-chrome";
    initArtCharts();
    initArticleChrome();
  </script>
</BaseLayout>
