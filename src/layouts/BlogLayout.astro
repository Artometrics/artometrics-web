---
import BaseLayout from "./BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import ShareButtons from "@/components/fundations/elements/ShareButtons.astro";
import { getCollection } from "astro:content";
import { SECTION_SLUGS } from "@/data/sections";

interface Props {
  frontmatter: {
    title: string;
    pubDate: Date | string;
    description: string;
    heroImage?: string;
  };
  slug: string;
}

const { frontmatter, slug } = Astro.props;

const pubDateFormatted = new Date(frontmatter.pubDate).toLocaleDateString(
  "en-US",
  {
    year: "numeric",
    month: "long",
    day: "numeric",
  }
);

function deckLine(description: string) {
  const trimmed = description.trim();
  const match = trimmed.match(/^(.+?[.!?])(?:\s|$)/);
  const line = match ? match[1] : trimmed.split(/\s+/).slice(0, 18).join(" ");
  return /[.!?]$/.test(line) ? line : `${line.replace(/[.!?]+$/, "")}.`;
}

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter(
    (post) =>
      post.data.slug !== slug && !SECTION_SLUGS.includes(post.data.slug)
  )
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 5)
  .map((post) => ({
    title: post.data.title,
    href: `/${post.data.slug}/`,
    deck: deckLine(post.data.description),
    image: post.data.heroImage,
  }));

const relatedJson = JSON.stringify(relatedPosts);
const articleUrl = new URL(`/${slug}/`, Astro.site).href;
---

<BaseLayout
  pageTitle={`${frontmatter.title} — Artometrics`}
  pageDescription={frontmatter.description}
  canonicalPath={`/${slug}/`}
  ogImage={
    frontmatter.heroImage
      ? new URL(frontmatter.heroImage, Astro.site ?? "https://artometrics.com").href
      : undefined
  }
>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    slot="head"
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=DM+Mono&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap"
  />
  <link slot="head" rel="stylesheet" href="/css/artometrics-article.css" />
  <article class="artometrics-article">
    <Wrapper variant="standard" class="pt-10 pb-6">
      <header class="max-w-3xl mx-auto border-b border-base-200 pb-6 text-center">
        <h1
          class="font-sans text-2xl md:text-3xl lg:text-[2rem] font-bold leading-tight text-base-900 text-pretty"
        >
          {frontmatter.title}
        </h1>
        <p class="mt-3 font-sans text-base md:text-lg text-base-600 leading-relaxed text-pretty">
          {deckLine(frontmatter.description)}
        </p>
        <ShareButtons
          class="mt-5"
          contentType="blog"
          title={frontmatter.title}
          description={deckLine(frontmatter.description)}
          url={articleUrl}
        />
        <p class="mt-4 text-xs uppercase tracking-wide text-base-500">
          <time datetime={new Date(frontmatter.pubDate).toISOString()}>
            {pubDateFormatted}
          </time>
        </p>
      </header>
      {
        frontmatter.heroImage && (
          <img
            src={frontmatter.heroImage}
            alt={frontmatter.title}
            width={1200}
            height={800}
            class="w-full max-w-4xl mx-auto mt-10 block"
            loading="eager"
            decoding="async"
          />
        )
      }
    </Wrapper>

    <div class="artometrics-article-body" data-related={relatedJson}>
      <slot />
    </div>
  </article>
  <script>
    import { initArtCharts } from "@/scripts/art-charts";
    import { initArticleChrome } from "@/scripts/art-article-chrome";
    initArtCharts();
    initArticleChrome();
  </script>
</BaseLayout>
