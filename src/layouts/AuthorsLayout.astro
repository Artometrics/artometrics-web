---
// Images
import { Image } from "astro:assets";
// Fundations
import BaseLayout from "./BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import BlogCard2 from "@/components/blog/BlogCard2.astro";
import PodcastCardText from "@/components/podcast/PodcastCardText.astro";
// Load all posts
import { getCollection } from "astro:content";
// Props
const { frontmatter } = Astro.props;

// Extract the author slug from the current URL
const authorSlug = Astro.url.pathname.split("/").filter(Boolean).pop();
// Format slug to human-friendly name
const authorName = authorSlug
  .split("-")
  .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
  .join(" ");

// Get all content
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const allPodcasts = await getCollection("podcast");

const relatedPosts = allPosts.filter(
  (post) => post.data.author === authorSlug
);

const relatedPodcasts = allPodcasts.filter(
  (episode) => episode.data.author === authorSlug
);

const socialLinks = [
  { label: "Twitter", href: frontmatter.socials?.twitter },
  { label: "LinkedIn", href: frontmatter.socials?.linkedin },
  {
    label: "Email",
    href: frontmatter.socials?.email
      ? `mailto:${frontmatter.socials.email}`
      : undefined,
  },
  { label: "Website", href: frontmatter.socials?.website },
].filter((link) => link.href && link.href !== "#_");
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <Image
          width={800}
          height={800}
          src={frontmatter.image.url}
          alt={frontmatter.image.alt}
          loading="lazy"
          decoding="async"
          class="w-full bg-base-50 object-cover sticky top-12 aspect-square grayscale"
        />
        <div class="lg:py-32">
          <div>
            <Text
              tag="h1"
              variant="display3XL"
              class="font-serif font-light tracking-tight text-base-900"
            >
              {frontmatter.name}
            </Text>
            <Text
              tag="p"
              variant="textXS"
              class="mt-1 font-medium uppercase text-base-600"
            >
              {frontmatter.role}
            </Text>

            <div class="flex flex-col justify-between h-full mt-4">
              {
                frontmatter.bio && (
                  <div class="flex flex-col gap-2">
                    {frontmatter.bio.split("\n").map((paragraph) => (
                      <Text
                        tag="p"
                        variant="textSM"
                        class="font-serif text-base-600"
                      >
                        {paragraph}
                      </Text>
                    ))}
                  </div>
                )
              }
              {/* Social Media Links */}
              {
                socialLinks.length > 0 && (
                  <div class="flex items-center mt-12 gap-4">
                    {socialLinks.map((link) => (
                      <a
                        href={link.href}
                        aria-label={link.label}
                        class="text-base-600 hover:text-base-900"
                      >
                        {link.label}
                      </a>
                    ))}
                  </div>
                )
              }
            </div>
          </div>
        </div>
      </div>
    </Wrapper>
  </section>
  <section>
    <Wrapper variant="standard" class="pt-32 pb-12">
      {
        relatedPosts.length > 0 && (
          <div>
            <Text
              tag="h2"
              variant="displayMD"
              class="font-serif font-light text-base-600"
            >
              More articles from {authorName}
            </Text>
            <div class="mt-2 grid grid-cols-1 gap-6 border-t border-base-200 pt-2 md:grid-cols-2">
              {relatedPosts.map((post) => (
                <BlogCard2 post={post} />
              ))}
            </div>
          </div>
        )
      }
    </Wrapper>
  </section>
  <section>
    <Wrapper variant="standard" class="pt-32 pb-12">
      {
        relatedPodcasts.length > 0 && (
          <div>
            <Text
              tag="h2"
              variant="displayMD"
              class="font-serif font-light text-base-600"
            >
              Interviews with {authorName}
            </Text>
            <div class="mt-2 grid grid-cols-1 gap-6 border-t border-base-200 pt-2 md:grid-cols-2">
              {relatedPodcasts.map((episode) => (
                <PodcastCardText post={episode} />
              ))}
            </div>
          </div>
        )
      }
    </Wrapper>
  </section>
</BaseLayout>
