---
import "@/styles/global.css";
import BaseHead from "@/components/fundations/head/BaseHead.astro";
import Footer from "@/components/global/Footer.astro";
import Navigation from "@/components/global/navigation/Navigation.astro";
import AudioPlayerScript from "@/components/fundations/scripts/AudioPlayerScript.astro";
import SiteChrome from "@/components/global/SiteChrome.astro";

interface Props {
  hideNav?: boolean;
  hideFooter?: boolean;
  pageTitle?: string;
  pageDescription?: string;
  canonicalPath?: string;
  ogImage?: string;
}

const {
  hideNav = false,
  hideFooter = false,
  pageTitle,
  pageDescription,
  canonicalPath,
  ogImage,
} = Astro.props;

const resolvedTitle = pageTitle ?? "Artometrics";
---

<html lang="en">
  <head>
    <BaseHead
      pageTitle={resolvedTitle}
      pageDescription={pageDescription}
      canonicalPath={canonicalPath}
      ogImage={ogImage}
    />
    <slot name="head" />
  </head>
  <body class="flex min-h-svh flex-col bg-base-50 antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[200] focus:rounded-md focus:bg-base-900 focus:px-4 focus:py-2 focus:text-sm focus:text-white"
    >
      Skip to content
    </a>
    {!hideNav && <Navigation />}
    <main id="main-content" class="grow"><slot /></main>
    {!hideFooter && <Footer />}
    <SiteChrome />
    <AudioPlayerScript />
  </body>
</html>
