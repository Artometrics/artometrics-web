---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<BaseLayout pageTitle="Page not found — Artometrics">
  <section class="flex min-h-[60vh] items-center">
    <Wrapper variant="standard" class="py-24 text-center">
      <Text tag="p" variant="textXS" class="uppercase tracking-[0.2em] text-accent-700">
        Error 404
      </Text>
      <Text
        tag="h1"
        variant="displayMD"
        class="mt-4 font-serif font-light uppercase tracking-wide text-base-900"
      >
        This page isn't in the dataset
      </Text>
      <Text tag="p" variant="textMD" class="mx-auto mt-4 max-w-md leading-relaxed text-base-600">
        The URL may have moved, or the report was never published. Head back to the homepage or search the archive.
      </Text>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a
          href="/"
          class="inline-flex items-center rounded-sm bg-base-900 px-5 py-2.5 text-xs font-semibold uppercase tracking-widest text-white transition-colors hover:bg-accent-800"
        >
          Home
        </a>
        <a
          href="/blog/"
          class="inline-flex items-center rounded-sm border border-base-300 px-5 py-2.5 text-xs font-semibold uppercase tracking-widest text-base-800 transition-colors hover:border-accent-400 hover:text-accent-800"
        >
          All articles
        </a>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
