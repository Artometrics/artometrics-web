---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Breadcrumbs from "@/components/blog/Breadcrumbs.astro";
---

<BaseLayout
  pageTitle="About — Artometrics"
  pageDescription="Artometrics publishes data-driven reports on culture, place, history, persona, and power."
  canonicalPath="/about"
>
  <section>
    <Wrapper variant="standard" class="py-16 md:py-24">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/" },
          { label: "About" },
        ]}
        class="mb-8"
      />
      <div class="mx-auto max-w-2xl">
        <Text tag="p" variant="textXS" class="uppercase tracking-[0.2em] text-accent-700">
          About
        </Text>
        <Text
          tag="h1"
          variant="displayMD"
          class="mt-3 font-serif font-light leading-tight text-base-900"
        >
          The Artometrics editorial desk
        </Text>
        <div class="mt-8 space-y-5 text-base-600 leading-relaxed">
          <p>
            Artometrics is an independent publication that treats culture like data — anime catalogs,
            franchise economics, civilizational cycles, and the institutions that shape creative markets.
            Every report pairs editorial judgment with reproducible charts and public datasets.
          </p>
          <p>
            The site is organized into five desks — <strong>Culture</strong>, <strong>Atlas</strong>,
            <strong>History</strong>, <strong>Persona</strong>, and <strong>Power</strong> — each with its
            own archive of long-form investigations. The podcast extends those themes through interviews
            with analysts, founders, and historians.
          </p>
          <p>
            Reports are built on community datasets (including TidyTuesday releases), open APIs, and
            primary sources cited in every article. We publish limitations alongside findings because
            measured uncertainty is part of the story. The shared methodology page explains how to
            distinguish observed data, derived metrics, editorial indices, and outside literature.
          </p>
        </div>
        <div class="mt-10 flex flex-wrap gap-3 border-t border-base-200 pt-8">
          <a
            href="/blog/"
            class="inline-flex items-center rounded-sm bg-base-900 px-5 py-2.5 text-xs font-semibold uppercase tracking-widest text-white transition-colors hover:bg-accent-800"
          >
            Browse reports
          </a>
          <a
            href="/podcast/"
            class="inline-flex items-center rounded-sm border border-base-300 px-5 py-2.5 text-xs font-semibold uppercase tracking-widest text-base-800 transition-colors hover:border-accent-400"
          >
            Listen to podcast
          </a>
          <a
            href="/methodology/"
            class="inline-flex items-center rounded-sm border border-base-300 px-5 py-2.5 text-xs font-semibold uppercase tracking-widest text-base-800 transition-colors hover:border-accent-400"
          >
            Methodology
          </a>
          <a
            href="/rss.xml"
            class="inline-flex items-center rounded-sm border border-base-300 px-5 py-2.5 text-xs font-semibold uppercase tracking-widest text-base-800 transition-colors hover:border-accent-400"
          >
            RSS feed
          </a>
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
