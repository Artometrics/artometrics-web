---
import BlogLayout from "@/layouts/BlogLayout.astro";
import { getCollection } from "astro:content";
import { SECTION_SLUGS } from "@/data/sections";
import { getAdjacentPosts } from "@/lib/blog";
import readingTime from "reading-time";

export async function getStaticPaths() {
  const entries = await getCollection("blog", ({ data }) => !data.draft);
  const allPosts = entries.filter((entry) => !SECTION_SLUGS.includes(entry.data.slug));

  return allPosts.map((entry) => {
    const { previous, next } = getAdjacentPosts(allPosts, entry.data.slug);
    return {
      params: { slug: entry.data.slug },
      props: {
        entry,
        previous,
        next,
        readingStats: readingTime(entry.body ?? ""),
      },
    };
  });
}

const { entry, previous, next, readingStats } = Astro.props;
---

<BlogLayout
  frontmatter={entry.data}
  slug={entry.data.slug}
  readingStats={readingStats}
  previous={previous}
  next={next}
>
  <div set:html={entry.body} />
</BlogLayout>
