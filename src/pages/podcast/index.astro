---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import PodcastCardWide from "@/components/podcast/PodcastCardWide.astro";
import PodcastCardSimple from "@/components/podcast/PodcastCardSimple.astro";
import Hero from "@/components/podcast/Hero.astro";
import { getCollection } from "astro:content";

const allPodcasts = await getCollection("podcast");
const sorted = allPodcasts
  .filter((item) => item.data?.pubDate)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const locked = allPodcasts.filter((post) => post.data.isLocked);
---

<BaseLayout
  pageTitle="Podcast — Artometrics"
  pageDescription="Artometrics podcast interviews on culture, power, and the creative economy."
  canonicalPath="/podcast/"
>
  <Hero />
  <section>
    <Wrapper variant="standard" class="pb-16 pt-10 md:pt-12">
      <Text tag="p" variant="textXS" class="uppercase tracking-[0.18em] text-base-500">
        Episodes
      </Text>
      <div class="mt-6 divide-y divide-base-200 border-t border-base-200">
        {sorted.map((post) => <PodcastCardWide post={post} />)}
      </div>
    </Wrapper>
  </section>
  {
    locked.length > 0 && (
      <section class="border-t border-base-200 bg-base-100">
        <Wrapper variant="standard" class="py-14">
          <Text tag="p" variant="textXS" class="uppercase tracking-[0.18em] text-accent-700">
            Members
          </Text>
          <Text tag="h2" variant="displayXS" class="mt-2 font-serif font-light uppercase tracking-wide">
            Subscribers only
          </Text>
          <div class="mt-8 grid grid-cols-1 gap-4 border-t border-base-200 pt-8 sm:grid-cols-2 md:grid-cols-4">
            {locked.map((post) => <PodcastCardSimple post={post} />)}
          </div>
        </Wrapper>
      </section>
    )
  }
</BaseLayout>
