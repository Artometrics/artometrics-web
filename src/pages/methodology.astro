---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Breadcrumbs from "@/components/blog/Breadcrumbs.astro";

const sourceGroups = [
  {
    title: "Report pipeline and community datasets",
    dek: "Sources used for broad, fast-moving public-data reports.",
    links: [
      {
        label: "TidyTuesday repository",
        href: "https://github.com/rfordatascience/tidytuesday",
        note: "Weekly social data project from the Data Science Learning Community; the bulk source for many public-data reports.",
      },
      {
        label: "tidytuesdayR documentation",
        href: "https://dslc-io.github.io/tidytuesdayR/",
        note: "R package documentation for loading TidyTuesday releases with source metadata.",
      },
    ],
  },
  {
    title: "Culture, media, and canon data",
    dek: "Reference sources for fame, film, music, literature, and cultural production.",
    links: [
      {
        label: "Pantheon 1.0 - Scientific Data",
        href: "https://doi.org/10.1038/sdata.2015.75",
        note: "Peer-reviewed dataset of globally famous biographies by Yu, Ronen, Hu, Lu, and Hidalgo.",
      },
      {
        label: "IMDb non-commercial datasets",
        href: "https://developer.imdb.com/non-commercial-datasets",
        note: "Official IMDb bulk files for non-commercial use; IMDb credit language is required where used.",
      },
      {
        label: "Project Gutenberg",
        href: "https://gutenberg.org/",
        note: "Volunteer-built library of more than 75,000 free ebooks, focused on older works with expired U.S. copyright.",
      },
      {
        label: "Project Gutenberg license policy",
        href: "https://www.gutenberg.org/policy/license.html",
        note: "Rights and reuse guidance for Gutenberg texts and metadata.",
      },
      {
        label: "MusicBrainz",
        href: "https://musicbrainz.org/",
        note: "Open music encyclopedia maintained by the MetaBrainz Foundation.",
      },
      {
        label: "MusicBrainz API",
        href: "https://musicbrainz.org/doc/MusicBrainz_API",
        note: "REST API documentation for artists, recordings, releases, works, labels, and related music metadata.",
      },
    ],
  },
  {
    title: "Economy, geography, and city identity",
    dek: "Official data portals for trade, regional economics, cities, and policy systems.",
    links: [
      {
        label: "OEC API",
        href: "https://oec.world/en/resources/api",
        note: "Observatory of Economic Complexity API for international and subnational trade data.",
      },
      {
        label: "UN Comtrade",
        href: "https://uncomtrade.org/docs/welcome-to-un-comtrade/",
        note: "UN Statistics Division trade database with goods and services imports/exports by country, partner, and product.",
      },
      {
        label: "BEA API",
        href: "https://apps.bea.gov/API/docs/index.htm",
        note: "U.S. Bureau of Economic Analysis API for national, regional, and international economic statistics.",
      },
      {
        label: "DataSF developer resources",
        href: "https://data.sfgov.org/developers",
        note: "San Francisco open data portal and Socrata API guidance for city-level datasets.",
      },
      {
        label: "Socrata API endpoints",
        href: "https://dev.socrata.com/docs/endpoints.html",
        note: "Documentation for the SODA endpoints used by many city and public-sector open-data portals.",
      },
    ],
  },
  {
    title: "Sports and institutional performance",
    dek: "Reference databases used for team identity, dynasty, and league comparison reports.",
    links: [
      {
        label: "Sports Reference",
        href: "https://www.sports-reference.com/",
        note: "Baseball, basketball, football, hockey, soccer, college, and historical sports reference databases.",
      },
      {
        label: "Stathead",
        href: "https://www.sports-reference.com/stathead/",
        note: "Sports Reference research layer for leaderboards, splits, streaks, spans, seasons, and games.",
      },
    ],
  },
  {
    title: "Health, policy, and institutions",
    dek: "Agency sources used when reports depend on official program definitions.",
    links: [
      {
        label: "CMS Hospital Readmissions Reduction Program",
        href: "https://www.cms.gov/medicare/payment/prospective-payment-systems/acute-inpatient-pps/hospital-readmissions-reduction-program-hrrp",
        note: "CMS program page for HRRP definitions, payment context, and official reporting pathways.",
      },
      {
        label: "CMS Provider Data Catalog - HRRP",
        href: "https://data.cms.gov/provider-data/dataset/9n3s-kdb3",
        note: "Official Provider Data Catalog table used for hospital readmission performance analysis.",
      },
    ],
  },
];

const standards = [
  {
    title: "Observed data",
    text: "Figures copied from a source table, API, or official dataset after cleaning. These are cited directly and should be reproducible from the listed source.",
  },
  {
    title: "Derived metrics",
    text: "Ratios, ranks, medians, concentrations, and indexes calculated from observed data. The report should explain the calculation in plain language.",
  },
  {
    title: "Editorial indices",
    text: "Framework scores used to compare identity, strength, weakness, or cultural position when no single public statistic exists. These are not official measures and must be labeled as interpretation.",
  },
  {
    title: "Context literature",
    text: "Peer-reviewed papers, agency documentation, official data dictionaries, and credible reference publications that help interpret what the data can and cannot prove.",
  },
];

const examples = [
  {
    label: "Observed data",
    href: "/readmitted/",
    title: "Hospital readmissions and CMS HRRP",
    note: "Official agency data, program definitions, and joined facility metadata.",
  },
  {
    label: "Derived metrics",
    href: "/anime/",
    title: "Anime industry structure",
    note: "Public catalog data transformed into format, popularity, and genre comparisons.",
  },
  {
    label: "Editorial index",
    href: "/national-export-identity-atlas/",
    title: "National export identity atlas",
    note: "A clearly labeled framework for comparing macroeconomic identity signals.",
  },
  {
    label: "Context literature",
    href: "/pantheon-the-artometrics-of-collective-memory/",
    title: "Pantheon and collective memory",
    note: "Culture analysis anchored by a peer-reviewed dataset publication.",
  },
];
---

<BaseLayout
  pageTitle="Methodology and Sources - Artometrics"
  pageDescription="How Artometrics reports use public data, derived metrics, editorial indices, and outside literature."
  canonicalPath="/methodology"
>
  <section>
    <Wrapper variant="standard" class="py-16 md:py-24">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/" },
          { label: "Methodology" },
        ]}
        class="mb-8"
      />

      <div class="mx-auto max-w-4xl">
        <Text tag="p" variant="textXS" class="uppercase tracking-[0.2em] text-accent-700">
          Methodology
        </Text>
        <Text
          tag="h1"
          variant="displayMD"
          class="mt-3 max-w-3xl font-serif font-light leading-tight text-base-900"
        >
          How to read Artometrics reports
        </Text>
        <div class="mt-8 grid gap-8 md:grid-cols-[1.35fr_0.85fr]">
          <div class="space-y-5 text-base-600 leading-relaxed">
            <p>
              Artometrics reports are built for two readers at once: a curious beginner who needs a
              clear path through the chart, and a domain expert who wants to know where the evidence
              came from. The chart headline is the first claim. The references, limitations, and
              editor notes are the audit trail.
            </p>
            <p>
              The site uses public datasets, official APIs, agency documentation, and published
              literature where available. Some reports are direct data analysis. Others are
              framework reports that use editorial indices to make a comparison possible. When a
              score is interpretive, the report should say so plainly.
            </p>
          </div>
          <div class="rounded-sm border border-base-200 bg-base-100 p-6">
            <Text tag="h2" variant="textLG" class="font-serif font-light text-base-900">
              Reader checklist
            </Text>
            <ul class="mt-4 space-y-3 text-sm leading-relaxed text-base-600">
              <li><strong>1.</strong> Read the chart caption as a claim.</li>
              <li><strong>2.</strong> Check whether the metric is observed, derived, or editorial.</li>
              <li><strong>3.</strong> Use the source link to inspect the underlying data.</li>
              <li><strong>4.</strong> Read limitations before turning a pattern into a conclusion.</li>
            </ul>
          </div>
        </div>

        <div class="mt-14 grid gap-4 md:grid-cols-2">
          {standards.map((item) => (
            <article class="rounded-sm border border-base-200 bg-white p-6">
              <Text tag="h2" variant="textLG" class="font-serif font-light text-base-900">
                {item.title}
              </Text>
              <p class="mt-3 text-sm leading-relaxed text-base-600">{item.text}</p>
            </article>
          ))}
        </div>

        <div class="mt-16 rounded-sm border border-base-200 bg-white p-6">
          <Text tag="p" variant="textXS" class="uppercase tracking-[0.2em] text-accent-700">
            Examples
          </Text>
          <Text tag="h2" variant="displayXS" class="mt-3 font-serif font-light text-base-900">
            Four ways evidence appears in reports
          </Text>
          <div class="mt-6 grid gap-3 md:grid-cols-2">
            {examples.map((item) => (
              <a
                href={item.href}
                class="rounded-sm border border-base-200 bg-base-50 p-4 transition-colors hover:border-accent-400"
              >
                <span class="text-[10px] font-semibold uppercase tracking-[0.18em] text-accent-700">
                  {item.label}
                </span>
                <span class="mt-2 block text-sm font-semibold text-base-900">{item.title}</span>
                <span class="mt-2 block text-xs leading-relaxed text-base-600">{item.note}</span>
              </a>
            ))}
          </div>
        </div>

        <div class="mt-16 border-t border-base-200 pt-12">
          <Text tag="p" variant="textXS" class="uppercase tracking-[0.2em] text-accent-700">
            Source library
          </Text>
          <Text tag="h2" variant="displayXS" class="mt-3 font-serif font-light text-base-900">
            Public data, literature, and reference tools
          </Text>
          <p class="mt-4 max-w-2xl text-base-600 leading-relaxed">
            These are recurring sources and literature anchors used to frame Artometrics reports.
            Individual reports still carry their own references; this page is the shared map.
          </p>

          <div class="mt-8 space-y-8">
            {sourceGroups.map((group) => (
              <section class="rounded-sm border border-base-200 bg-base-50 p-6">
                <div class="max-w-2xl">
                  <Text tag="h3" variant="textXL" class="font-serif font-light text-base-900">
                    {group.title}
                  </Text>
                  <p class="mt-2 text-sm leading-relaxed text-base-600">{group.dek}</p>
                </div>
                <div class="mt-5 grid gap-3 md:grid-cols-2">
                  {group.links.map((link) => (
                    <a
                      href={link.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="group rounded-sm border border-base-200 bg-white p-4 transition-colors hover:border-accent-400"
                    >
                      <span class="text-sm font-semibold text-base-900 group-hover:text-accent-800">
                        {link.label}
                      </span>
                      <span class="mt-2 block text-xs leading-relaxed text-base-500">
                        {link.note}
                      </span>
                    </a>
                  ))}
                </div>
              </section>
            ))}
          </div>
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
