---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import { PLANS } from "@/lib/product/plans";
---

<BaseLayout
  pageTitle="Membership — Artometrics"
  pageDescription="Subscribe to unlock subscriber-only podcast episodes, saved reports, and member features."
  canonicalPath="/pricing/"
>
  <section>
    <Wrapper variant="standard" class="py-24">
      <div class="max-w-3xl">
        <Text
          tag="h1"
          variant="displayMD"
          class="font-serif font-light leading-6 md:leading-8 text-base-600"
        >
          <span class="text-base-900">Membership:</span> Unlock the full podcast library,
          save reports, and support independent data journalism
        </Text>
      </div>

      <div
        class="pt-12 mt-2 border-t border-black grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-16"
      >
        {
          PLANS.map((plan) => (
            <div
              class:list={[
                "flex flex-col justify-between h-full gap-12 rounded-lg border p-6",
                plan.popular ? "border-accent-400 bg-accent-50/30" : "border-base-200",
              ]}
            >
              <div>
                {plan.popular && (
                  <span class="text-[10px] font-semibold uppercase tracking-widest text-accent-700">
                    Most popular
                  </span>
                )}
                <Text tag="p" variant="display2XL" class="font-serif font-light">
                  {plan.price}
                </Text>
                <Text tag="p" variant="textXS" class="font-serif text-base-600">
                  {plan.period}
                </Text>
                <Text
                  tag="h3"
                  variant="textXS"
                  class="mt-8 font-medium text-base-900 uppercase"
                >
                  {plan.title}
                </Text>
                <ul class="mt-4 text-sm space-y-3">
                  {plan.features.map((feature) => (
                    <li class="font-serif list-disc text-base-600">{feature}</li>
                  ))}
                </ul>
              </div>
              <div>
                <Button
                  size="sm"
                  variant={plan.popular ? "default" : "muted"}
                  type="button"
                  data-checkout-tier={plan.tier}
                >
                  Subscribe
                </Button>
              </div>
            </div>
          ))
        }
      </div>

      <div class="mt-16 border-t border-base-200 pt-10">
        <Text tag="h2" variant="textXS" class="font-medium uppercase text-base-900">
          Enterprise & teams
        </Text>
        <Text tag="p" variant="textSM" class="mt-2 max-w-xl text-base-600">
          Need bulk access, custom reporting, or API integrations? Contact us for
          tailored plans.
        </Text>
        <Button isLink size="sm" variant="muted" href="/contact/" class="mt-4">
          Contact sales
        </Button>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
