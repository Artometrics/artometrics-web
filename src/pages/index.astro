---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogCard2 from "@/components/blog/BlogCard2.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import { getCollection } from "astro:content";
import { SECTION_META } from "@/data/sections";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = allPosts
  .filter((post) => post.data?.pubDate)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const allPodcasts = await getCollection("podcast");
const sortedPodcasts = allPodcasts
  .filter((item) => item.data?.pubDate)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const featured = sortedPosts[0];
const rest = sortedPosts.slice(1);
const latestPodcasts = sortedPodcasts.slice(0, 2);

const weekAgo = Date.now() - 7 * 24 * 60 * 60 * 1000;
const weekPosts = sortedPosts
  .filter((post) => post.data.pubDate.getTime() >= weekAgo && post.id !== featured?.id)
  .slice(0, 4);
const editorialPicks =
  weekPosts.length > 0 ? weekPosts : sortedPosts.slice(1, 5);

function deckLine(description: string) {
  const trimmed = description.trim();
  const match = trimmed.match(/^(.+?[.!?])(?:\s|$)/);
  const line = match ? match[1] : trimmed.split(/\s+/).slice(0, 22).join(" ");
  return /[.!?]$/.test(line) ? line : `${line.replace(/[.!?]+$/, "")}.`;
}

function formatAuthorName(slug: string) {
  return slug
    .replace(/-/g, " ")
    .split(" ")
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
}

const sectionCounts = Object.fromEntries(
  Object.keys(SECTION_META).map((slug) => [
    slug,
    sortedPosts.filter((p) => p.data.tags?.includes(slug as keyof typeof SECTION_META)).length,
  ])
);
---

<BaseLayout
  pageTitle="Artometrics — Data reports on culture, power, and the creative economy"
  pageDescription="Editorial data reports and podcast interviews on culture, atlas, history, persona, and power."
  canonicalPath="/"
>
  <section id="homeContinueReading" class="border-b border-base-200 bg-accent-50/30" hidden>
    <Wrapper variant="standard" class="py-8">
      <div id="homeContinueReadingCard"></div>
    </Wrapper>
  </section>

  {
    featured && (
      <section class="border-b border-base-200 bg-base-100">
        <Wrapper variant="standard" class="py-10 md:py-14">
          <div class="grid items-center gap-8 lg:grid-cols-2 lg:gap-12">
            <div class="order-2 lg:order-1">
              <Text tag="p" variant="textXS" class="uppercase tracking-[0.2em] text-accent-700">
                Latest report
              </Text>
              <Text
                tag="h1"
                variant="displaySM"
                class="mt-3 font-serif font-light leading-tight text-base-900 text-pretty"
              >
                <a href={`/${featured.data.slug}/`} class="hover:text-accent-800 transition-colors">
                  {featured.data.title}
                </a>
              </Text>
              <Text tag="p" variant="textMD" class="mt-4 max-w-xl leading-relaxed text-base-600 text-pretty">
                {deckLine(featured.data.description)}
              </Text>
              <div class="mt-6 flex flex-wrap items-center gap-3">
                <a
                  href={`/${featured.data.slug}/`}
                  class="inline-flex items-center rounded-sm bg-base-900 px-5 py-2.5 text-xs font-semibold uppercase tracking-widest text-white transition-colors hover:bg-accent-800"
                >
                  Read report
                </a>
                <Text tag="p" variant="textXS" class="text-base-500">
                  {new Date(featured.data.pubDate).toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </Text>
              </div>
            </div>
            {
              featured.data.heroImage && (
                <a
                  href={`/${featured.data.slug}/`}
                  class="order-1 block overflow-hidden border border-base-200 bg-white lg:order-2"
                >
                  <img
                    src={featured.data.heroImage}
                    alt={featured.data.title}
                    width={1200}
                    height={675}
                    class="aspect-video w-full object-cover transition-transform duration-500 hover:scale-[1.02]"
                    loading="eager"
                    decoding="async"
                  />
                </a>
              )
            }
          </div>
        </Wrapper>
      </section>
    )
  }

  {
    editorialPicks.length > 0 && (
      <section class="border-b border-base-200 bg-white">
        <Wrapper variant="standard" class="py-12 md:py-14">
          <div class="mb-8 flex flex-wrap items-end justify-between gap-4 border-b border-base-200 pb-4">
            <div>
              <Text tag="p" variant="textXS" class="uppercase tracking-[0.18em] text-accent-700">
                {weekPosts.length > 0 ? "This week" : "Editor's picks"}
              </Text>
              <Text tag="h2" variant="displayXS" class="mt-1 font-serif font-light uppercase tracking-wide">
                {weekPosts.length > 0 ? "This week in Artometrics" : "Worth your time"}
              </Text>
            </div>
            <a
              href="/blog/"
              class="text-xs font-medium uppercase tracking-widest text-base-600 transition-colors hover:text-accent-700"
            >
              All reports →
            </a>
          </div>
          <div class="grid gap-6 md:grid-cols-2">
            {
              editorialPicks.map((post) => (
                <article class="group border border-base-200 bg-base-50 p-5 transition-all hover:border-base-400 hover:shadow-sm">
                  <Text tag="p" variant="textXS" class="uppercase tracking-wide text-base-400">
                    {new Date(post.data.pubDate).toLocaleDateString("en-US", {
                      month: "short",
                      day: "numeric",
                    })}
                    {post.data.tags?.[0] && (
                      <>
                        {" · "}
                        <span class="text-accent-700">{post.data.tags[0]}</span>
                      </>
                    )}
                  </Text>
                  <Text tag="h3" variant="textMD" class="mt-2 font-serif font-light leading-snug text-base-900">
                    <a href={`/${post.data.slug}/`} class="hover:text-accent-800">
                      {post.data.title}
                    </a>
                  </Text>
                  <Text tag="p" variant="textSM" class="mt-2 line-clamp-2 text-base-600">
                    {deckLine(post.data.description)}
                  </Text>
                </article>
              ))
            }
          </div>
        </Wrapper>
      </section>
    )
  }

  <section class="border-b border-base-200">
    <Wrapper variant="standard" class="py-8">
      <Text tag="p" variant="textXS" class="text-center uppercase tracking-[0.18em] text-base-500">
        Browse by desk
      </Text>
      <div class="mt-4 flex flex-wrap justify-center gap-2 md:gap-3">
        {
          Object.entries(SECTION_META).map(([slug, meta]) => (
            <a
              href={`/${slug}/`}
              class="group inline-flex items-center gap-2 rounded-full border border-base-200 bg-white px-4 py-2 text-xs font-medium uppercase tracking-wide text-base-800 transition-all hover:border-accent-400 hover:bg-accent-50 hover:text-accent-800"
            >
              {meta.title}
              <span class="rounded-full bg-base-100 px-1.5 py-0.5 text-[10px] tabular-nums text-base-500 group-hover:bg-accent-100 group-hover:text-accent-700">
                {sectionCounts[slug] ?? 0}
              </span>
            </a>
          ))
        }
      </div>
    </Wrapper>
  </section>

  {
    latestPodcasts.length > 0 && (
      <section class="border-b border-base-200 bg-white">
        <Wrapper variant="standard" class="py-12 md:py-14">
          <div class="mb-8 flex flex-wrap items-end justify-between gap-4 border-b border-base-200 pb-4">
            <div>
              <Text tag="p" variant="textXS" class="uppercase tracking-[0.18em] text-accent-700">
                Podcast
              </Text>
              <Text tag="h2" variant="displayXS" class="mt-1 font-serif font-light uppercase tracking-wide">
                Latest interviews
              </Text>
            </div>
            <a
              href="/podcast/"
              class="text-xs font-medium uppercase tracking-widest text-base-600 transition-colors hover:text-accent-700"
            >
              All episodes →
            </a>
          </div>
          <div class="grid gap-6 md:grid-cols-2">
            {
              latestPodcasts.map((episode) => (
                <article class="group relative flex gap-4 border border-base-200 bg-base-50 p-4 transition-all hover:border-base-400 hover:shadow-md md:p-5">
                  <a
                    href={`/podcast/interviews/${episode.id}`}
                    class="absolute inset-0 z-10"
                    aria-label={`Listen: ${episode.data.title}`}
                  />
                  {
                    episode.data.image?.url && (
                      <img
                        src={episode.data.image.url}
                        alt=""
                        width={120}
                        height={120}
                        class="size-20 shrink-0 object-cover md:size-24"
                        loading="lazy"
                      />
                    )
                  }
                  <div class="min-w-0 flex-1">
                    <Text tag="p" variant="textXS" class="uppercase tracking-wide text-base-400">
                      {formatAuthorName(episode.data.author)}
                    </Text>
                    <Text tag="h3" variant="textSM" class="mt-1 font-bold leading-snug text-base-900 text-pretty">
                      {episode.data.title}
                    </Text>
                    <Text tag="p" variant="textSM" class="mt-2 line-clamp-2 text-base-600">
                      {episode.data.description}
                    </Text>
                  </div>
                </article>
              ))
            }
          </div>
        </Wrapper>
      </section>
    )
  }

  <section>
    <Wrapper variant="standard" class="pt-12 pb-24">
      <div class="mb-8 flex flex-wrap items-end justify-between gap-4 border-b border-base-200 pb-4">
        <Text tag="h2" variant="displayXS" class="font-serif font-light uppercase tracking-wide">
          All reports
        </Text>
        <a
          href="/blog/"
          class="text-xs font-medium uppercase tracking-widest text-base-600 transition-colors hover:text-accent-700"
        >
          View archive →
        </a>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4">
        {rest.map((post, i) => (
          <BlogCard2 post={post} eagerImage={i < 4} />
        ))}
      </div>
    </Wrapper>
  </section>
</BaseLayout>
