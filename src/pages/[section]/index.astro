---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import BlogCard2 from "@/components/blog/BlogCard2.astro";
import Breadcrumbs from "@/components/blog/Breadcrumbs.astro";
import { getCollection } from "astro:content";
import { SECTION_META } from "@/data/sections";
import { publishedPosts } from "@/lib/blog";

export function getStaticPaths() {
  return Object.entries(SECTION_META).map(([slug, meta]) => ({
    params: { section: slug },
    props: { section: { slug, ...meta } },
  }));
}

const { section } = Astro.props;
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const sectionPosts = publishedPosts(allPosts).filter((post) =>
  post.data.tags.includes(section.slug as keyof typeof SECTION_META)
);
---

<BaseLayout
  pageTitle={`${section.title} Desk — Artometrics`}
  pageDescription={section.description}
  canonicalPath={`/${section.slug}/`}
>
  <section>
    <Wrapper variant="standard" class="pt-16 pb-16 md:pt-24">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/" },
          { label: section.title },
        ]}
        class="mb-6"
      />
      <Text tag="p" variant="textXS" class="uppercase tracking-[0.18em] text-accent-700">
        Desk
      </Text>
      <Text tag="h1" variant="displayLG" class="mt-2 font-serif font-light uppercase tracking-wide">
        {section.title}
      </Text>
      <Text tag="p" variant="textSM" class="mt-4 max-w-2xl leading-relaxed text-base-600 text-pretty">
        {section.description}
      </Text>
      <Text tag="p" variant="textXS" class="mt-3 text-base-500">
        {sectionPosts.length} report{sectionPosts.length === 1 ? "" : "s"}
      </Text>
      <div
        class="mt-10 grid grid-cols-1 gap-6 border-t border-base-200 pt-8 sm:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4"
      >
        {sectionPosts.map((post, i) => (
          <BlogCard2 post={post} eagerImage={i < 3} />
        ))}
      </div>
      {
        sectionPosts.length === 0 && (
          <Text tag="p" variant="textSM" class="mt-8 text-base-500">
            No articles in this section yet.
          </Text>
        )
      }
    </Wrapper>
  </section>
</BaseLayout>
