---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import BlogCard2 from "@/components/blog/BlogCard2.astro";
import Breadcrumbs from "@/components/blog/Breadcrumbs.astro";
import { getCollection } from "astro:content";
import { SECTION_META } from "@/data/sections";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  const uniqueTags = [
    ...new Set(allPosts.map((post) => post.data.tags).flat()),
  ];
  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts.filter((post) =>
      post.data.tags.includes(tag)
    );
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}
const { tag } = Astro.params;
const { posts } = Astro.props;
const meta = tag && tag in SECTION_META ? SECTION_META[tag as keyof typeof SECTION_META] : null;
const title = meta?.title ?? tag;
---

<BaseLayout
  pageTitle={`${title} reports - Artometrics`}
  pageDescription={meta?.description ?? `Artometrics reports tagged ${tag}.`}
  canonicalPath={`/blog/tags/${tag}/`}
>
  <section>
    <Wrapper variant="standard" class="py-16 md:py-24">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/" },
          { label: "Reports", href: "/blog/" },
          { label: "Desks", href: "/blog/tags/" },
          { label: title ?? "Desk" },
        ]}
        class="mb-8"
      />
      <div class="max-w-2xl">
        <Text tag="p" variant="textXS" class="uppercase tracking-[0.2em] text-accent-700">
          Report desk
        </Text>
        <Text
          tag="h1"
          variant="displayMD"
          class="mt-3 font-serif font-light text-base-900"
        >
          {title} reports
        </Text>
        <p class="mt-4 text-sm leading-relaxed text-base-600">
          {meta?.description ?? `Reports grouped by ${tag}.`}
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          <a
            href={`/${tag}/`}
            class="rounded-full border border-base-200 bg-white px-3 py-1.5 text-[10px] font-semibold uppercase tracking-wider text-base-700 transition-colors hover:border-accent-400 hover:text-accent-800"
          >
            Desk hub
          </a>
          <a
            href="/methodology/"
            class="rounded-full border border-base-200 bg-white px-3 py-1.5 text-[10px] font-semibold uppercase tracking-wider text-base-700 transition-colors hover:border-accent-400 hover:text-accent-800"
          >
            Methodology
          </a>
          <span class="rounded-full border border-base-200 bg-base-100 px-3 py-1.5 text-[10px] font-semibold uppercase tracking-wider text-base-500">
            {posts.length} reports
          </span>
        </div>
      </div>

      <div
        class="mt-12 grid grid-cols-1 gap-6 border-t border-base-200 pt-8 md:grid-cols-2 lg:grid-cols-3"
      >
        {posts.map((post) => <BlogCard2 post={post} />)}
      </div>
    </Wrapper>
  </section>
</BaseLayout>
