---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Breadcrumbs from "@/components/blog/Breadcrumbs.astro";
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SECTION_META } from "@/data/sections";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const tags = [...new Set(allPosts.map((post) => post.data.tags).flat())];
---

<BaseLayout
  pageTitle="Report desks - Artometrics"
  pageDescription="Browse Artometrics reports by editorial desk."
  canonicalPath="/blog/tags/"
>
  <section>
    <Wrapper variant="standard" class="py-16 md:py-24">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/" },
          { label: "Reports", href: "/blog/" },
          { label: "Desks" },
        ]}
        class="mb-8"
      />
      <div class="mx-auto max-w-2xl text-center">
        <Text tag="p" variant="textXS" class="uppercase tracking-[0.2em] text-accent-700">
          Report desks
        </Text>
        <Text tag="h1" variant="displayMD" class="mt-3 font-serif font-light text-base-900">
          Browse by analytical lens
        </Text>
        <p class="mt-4 text-sm leading-relaxed text-base-600">
          These desks are not just topics. They are ways of asking questions about culture, place,
          history, persona, and power.
        </p>
      </div>
      <ul role="list" class="mx-auto mt-12 grid max-w-4xl gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          tags.map((tag) => (
            <li>
              <a
                href={`/blog/tags/${tag}/`}
                class="block h-full rounded-sm border border-base-200 bg-white p-5 transition-colors hover:border-accent-400"
              >
                <span class="text-[10px] font-semibold uppercase tracking-[0.18em] text-accent-700">
                  {tag}
                </span>
                <span class="mt-2 block font-serif text-2xl font-light text-base-900">
                  {tag in SECTION_META ? SECTION_META[tag as keyof typeof SECTION_META].title : tag}
                </span>
                <span class="mt-3 block text-sm leading-relaxed text-base-600">
                  {tag in SECTION_META
                    ? SECTION_META[tag as keyof typeof SECTION_META].description
                    : "Reports grouped by shared source material and questions."}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </Wrapper>
  </section>
</BaseLayout>
