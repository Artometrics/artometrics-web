---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import BlogCard2 from "@/components/blog/BlogCard2.astro";
import Breadcrumbs from "@/components/blog/Breadcrumbs.astro";
import ArchiveLoadMore from "@/components/blog/ArchiveLoadMore.astro";
import { getCollection } from "astro:content";
import { publishedPosts } from "@/lib/blog";

const sortedPosts = publishedPosts(await getCollection("blog", ({ data }) => !data.draft));
---

<BaseLayout
  pageTitle="Reports - Artometrics"
  pageDescription={`${sortedPosts.length} data reports on culture, power, and the creative economy.`}
  canonicalPath="/blog/"
>
  <section>
    <Wrapper variant="standard" class="pt-16 pb-16 md:pt-24">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/" },
          { label: "Reports" },
        ]}
        class="mb-6"
      />
      <Text tag="p" variant="textXS" class="uppercase tracking-[0.18em] text-accent-700">
        Archive
      </Text>
      <Text tag="h1" variant="displayMD" class="mt-2 font-serif font-light uppercase tracking-wide">
        All Reports
      </Text>
      <Text tag="p" variant="textSM" class="mt-3 max-w-2xl text-base-600">
        {sortedPosts.length} data reports on culture, power, and the creative economy.
      </Text>

      <div
        id="archiveGrid"
        class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4"
      >
        {
          sortedPosts.map((post, i) => (
            <div class="archive-item">
              <BlogCard2 post={post} eagerImage={i < 4} />
            </div>
          ))
        }
      </div>

      <ArchiveLoadMore total={sortedPosts.length} pageSize={18} />
    </Wrapper>
  </section>
</BaseLayout>
