---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import BlogCard2 from "@/components/blog/BlogCard2.astro";
import Subscribe from "@/components/ctas/Subscribe.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout pageTitle="Articles — Artometrics">
  <section>
    <Wrapper variant="standard" class="pt-32 pb-12">
      <Text tag="h1" variant="displayMD" class="font-serif font-light uppercase">
        All Articles
      </Text>
      <div
        class="items-start pt-8 mt-8 border-t border-black grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-y-12 gap-x-4"
      >
        {sortedPosts.map((post) => <BlogCard2 post={post} />)}
      </div>
    </Wrapper>
  </section>
  <Subscribe />
</BaseLayout>
