---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import BlogCard2 from "@/components/blog/BlogCard2.astro";
import Breadcrumbs from "@/components/blog/Breadcrumbs.astro";
import ArchiveLoadMore from "@/components/blog/ArchiveLoadMore.astro";
import { getCollection } from "astro:content";
import { SECTION_META } from "@/data/sections";
import { publishedPosts } from "@/lib/blog";

const sortedPosts = publishedPosts(await getCollection("blog", ({ data }) => !data.draft));

const sectionCounts = Object.fromEntries(
  Object.keys(SECTION_META).map((slug) => [
    slug,
    sortedPosts.filter((p) => p.data.tags?.includes(slug as keyof typeof SECTION_META)).length,
  ])
);
---

<BaseLayout
  pageTitle="Reports - Artometrics"
  pageDescription={`${sortedPosts.length} data reports across culture, atlas, history, persona, and power.`}
  canonicalPath="/blog/"
>
  <section>
    <Wrapper variant="standard" class="pt-16 pb-16 md:pt-24">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/" },
          { label: "Reports" },
        ]}
        class="mb-6"
      />
      <Text tag="p" variant="textXS" class="uppercase tracking-[0.18em] text-accent-700">
        Archive
      </Text>
      <Text tag="h1" variant="displayMD" class="mt-2 font-serif font-light uppercase tracking-wide">
        All Reports
      </Text>
      <Text tag="p" variant="textSM" class="mt-3 max-w-2xl text-base-600">
        {sortedPosts.length} data reports across culture, atlas, history, persona, and power.
      </Text>
      <div class="mt-5 flex flex-wrap gap-2">
        <a
          href="/methodology/"
          class="rounded-full border border-base-200 bg-white px-3 py-1.5 text-[10px] font-semibold uppercase tracking-wider text-base-700 transition-colors hover:border-accent-400 hover:text-accent-800"
        >
          How to read the evidence
        </a>
        <a
          href="/blog/tags/"
          class="rounded-full border border-base-200 bg-white px-3 py-1.5 text-[10px] font-semibold uppercase tracking-wider text-base-700 transition-colors hover:border-accent-400 hover:text-accent-800"
        >
          Browse desks
        </a>
      </div>

      <div
        id="archiveFilters"
        class="sticky top-[4.5rem] z-30 -mx-1 mt-8 flex flex-wrap gap-2 border-y border-base-200 bg-base-50/95 py-4 backdrop-blur-sm md:top-[7.25rem]"
        role="toolbar"
        aria-label="Filter by desk"
      >
        <button
          type="button"
          data-desk="all"
          class="archive-filter is-active rounded-full border border-base-900 bg-base-900 px-4 py-1.5 text-[10px] font-semibold uppercase tracking-wider text-white transition-colors"
        >
          All
          <span class="ml-1 tabular-nums opacity-70">{sortedPosts.length}</span>
        </button>
        {
          Object.entries(SECTION_META).map(([slug, meta]) => (
            <button
              type="button"
              data-desk={slug}
              class="archive-filter rounded-full border border-base-200 bg-white px-4 py-1.5 text-[10px] font-semibold uppercase tracking-wider text-base-700 transition-colors hover:border-accent-400 hover:text-accent-800"
            >
              {meta.title}
              <span class="ml-1 tabular-nums text-base-400">{sectionCounts[slug] ?? 0}</span>
            </button>
          ))
        }
      </div>

      <p id="archiveEmpty" class="mt-10 hidden text-center text-sm text-base-500">
        No reports on this desk yet.
      </p>

      <div
        id="archiveGrid"
        class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4"
      >
        {
          sortedPosts.map((post, i) => {
            const desks = (post.data.tags ?? []).filter(
              (t: string) => t in SECTION_META
            );
            return (
              <div data-desks={desks.join(",")} class="archive-item">
                <BlogCard2 post={post} eagerImage={i < 4} />
              </div>
            );
          })
        }
      </div>

      <ArchiveLoadMore total={sortedPosts.length} pageSize={18} />
    </Wrapper>
  </section>
</BaseLayout>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>(".archive-filter");
  const items = document.querySelectorAll<HTMLElement>(".archive-item");
  const empty = document.getElementById("archiveEmpty");
  const grid = document.getElementById("archiveGrid");

  function setActive(btn: HTMLButtonElement) {
    filters.forEach((b) => {
      const active = b === btn;
      b.classList.toggle("is-active", active);
      b.classList.toggle("border-base-900", active);
      b.classList.toggle("bg-base-900", active);
      b.classList.toggle("text-white", active);
      b.classList.toggle("border-base-200", !active);
      b.classList.toggle("bg-white", !active);
      b.classList.toggle("text-base-700", !active);
    });
  }

  filters.forEach((btn) => {
    btn.addEventListener("click", () => {
      const desk = btn.dataset.desk ?? "all";
      setActive(btn);
      let visible = 0;
      items.forEach((item) => {
        const desks = (item.dataset.desks ?? "").split(",").filter(Boolean);
        const show = desk === "all" || desks.includes(desk);
        item.classList.toggle("archive-filter-hidden", !show);
        item.classList.toggle("hidden", !show);
        if (show) visible += 1;
      });
      empty?.classList.toggle("hidden", visible > 0);
      grid?.dispatchEvent(new CustomEvent("archive-filter-change"));
    });
  });
</script>

<style>
  .archive-filter-hidden {
    display: none !important;
  }
</style>
