---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import BlogCard2 from "@/components/blog/BlogCard2.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout pageTitle="Articles — Artometrics">
  <section>
    <Wrapper variant="standard" class="pt-16 pb-12 md:pt-24">
      <Text tag="p" variant="textXS" class="uppercase tracking-[0.18em] text-accent-700">
        Archive
      </Text>
      <Text tag="h1" variant="displayMD" class="mt-2 font-serif font-light uppercase tracking-wide">
        All Articles
      </Text>
      <Text tag="p" variant="textSM" class="mt-3 max-w-2xl text-base-600">
        {sortedPosts.length} data reports across culture, atlas, history, persona, and power.
      </Text>
      <div class="mt-10 grid grid-cols-1 gap-6 border-t border-base-200 pt-8 sm:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4">
        {sortedPosts.map((post, i) => (
          <BlogCard2 post={post} eagerImage={i < 4} />
        ))}
      </div>
    </Wrapper>
  </section>
</BaseLayout>
