---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const pageSections = [
  {
    title: "Site",
    columns: [
      {
        category: "Pages",
        links: [
          { text: "Home", href: "/" },
          { text: "About", href: "/about" },
          { text: "Methodology", href: "/methodology/" },
          { text: "Membership", href: "/pricing/" },
          { text: "404", href: "/404" },
        ],
      },
      {
        category: "Account",
        links: [
          { text: "Login", href: "/login/" },
          { text: "Sign up", href: "/signup/" },
          { text: "Account", href: "/account/" },
          { text: "Contact", href: "/contact/" },
        ],
      },
      {
        category: "Design system",
        links: [
          { text: "Colors", href: "/system/colors" },
          { text: "Links", href: "/system/link" },
          { text: "Buttons", href: "/system/buttons" },
          { text: "Typography", href: "/system/typography" },
        ],
      },
      {
        category: "Artometrics",
        links: [
          { text: "GitHub", href: "https://github.com/Artometrics" },
          { text: "X / Twitter", href: "https://twitter.com/artometrics" },
          { text: "RSS", href: "/rss.xml" },
          { text: "Ethics", href: "/legal/ethics-statement" },
        ],
      },
    ],
  },
  {
    title: "Content",
    columns: [
      {
        category: "Reports",
        links: [
          { text: "All reports", href: "/blog/" },
          { text: "Sample report", href: "/anime/" },
          { text: "Culture desk", href: "/culture/" },
          { text: "Tag index", href: "/blog/tags" },
          { text: "RSS", href: "/rss.xml" },
        ],
      },
      {
        category: "Podcast",
        links: [
          { text: "Podcast home", href: "/podcast/" },
          { text: "Episode (open)", href: "/podcast/interviews/2" },
          { text: "Episode (member)", href: "/podcast/interviews/1" },
          { text: "Tag index", href: "/podcast/tags" },
          { text: "Tag: culture", href: "/podcast/tags/culture" },
        ],
      },
      {
        category: "Authors",
        links: [
          { text: "Authors", href: "/authors/" },
          { text: "Juliet Ramos", href: "/authors/juliet-ramos" },
        ],
      },
      {
        category: "Legal",
        links: [
          { text: "Privacy", href: "/legal/privacy" },
          { text: "Terms", href: "/legal/terms" },
          { text: "Cookies", href: "/legal/cookies" },
          { text: "DPA", href: "/legal/dpa" },
        ],
      },
    ],
  },
];
---

<BaseLayout pageTitle="Site overview — Artometrics">
  <section>
    <Wrapper variant="standard" class="py-24">
      <Text
        tag="h1"
        variant="displaySM"
        class="font-medium text-base-900 uppercase"
      >
        Artometrics site map
      </Text>
      <Text tag="p" variant="textSM" class="mt-3 max-w-2xl text-base-600">
        Internal index of public routes, content collections, and design-system pages for the Artometrics magazine site.
      </Text>
      <div class="mt-12 flex flex-col gap-12 gap-4">
        {
          pageSections.map((section) => (
            <div>
              <Text
                tag="h3"
                variant="textBase"
                class="font-serif text-base-900 "
              >
                {section.title}
              </Text>
              <div class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-5 mt-4  gap-8 lg:col-span-3">
                {section.columns.map((column) => (
                  <div class="flex flex-col gap-">
                    <Text
                      tag="p"
                      variant="textXS"
                      class="font-medium text-base-900 uppercase"
                    >
                      {column.category}
                    </Text>
                    <ul role="list" class="mt-1 list-none">
                      {column.links.map((link) => (
                        <li>
                          <Text
                            tag="a"
                            variant="textXS"
                            class="font-medium text-base-600 hover:text-base-900 hover:underline "
                            href={link.href}
                          >
                            {link.text}
                          </Text>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </Wrapper>
  </section>
</BaseLayout>
